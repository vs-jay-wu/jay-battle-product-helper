<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/mvb_spacing_300"
    tools:ignore="ContentDescription">

    <FrameLayout
        android:id="@+id/ll_shell_root"
        android:layout_width="@dimen/quiz_mvb_poll_start_window_width"
        android:layout_height="@dimen/quiz_mvb_poll_start_window_height"
        android:background="@drawable/bg_cs_window_no_border_radius800"
        android:clipToOutline="true"
        android:elevation="@dimen/mvb_spacing_200"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <FrameLayout
                android:id="@+id/fl_header"
                android:layout_width="match_parent"
                android:layout_height="@dimen/quiz_mvb_header_height"
                android:background="@color/neutral_0"
                android:paddingHorizontal="@dimen/mvb_spacing_400">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start|center_vertical"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/mvb_spacing_800"
                        android:layout_height="@dimen/mvb_spacing_800"
                        android:layout_marginEnd="@dimen/mvb_spacing_200"
                        android:src="@drawable/ic_mvb_quizzing_header"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tv_header_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="@string/quiz_title"
                        android:textColor="@color/neutral_900"
                        android:textSize="@dimen/quiz_mvb_text_md"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_minimize_window"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_marginEnd="@dimen/mvb_spacing_400"
                        android:src="@drawable/ic_minus_32dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        android:visibility="gone"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_toolbar_bring_to_front"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_marginEnd="@dimen/mvb_spacing_300"
                        android:src="@drawable/ic_toolbar_bring_to_front_64dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        android:visibility="gone"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_close"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:src="@drawable/ic_close_64dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />
                </LinearLayout>
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_E6E6E6" />

            <include
                android:id="@+id/panel_quizzing"
                layout="@layout/panel_mvb_quizzing"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1" />
        </LinearLayout>

        <com.viewsonic.classswift.ui.widget.MvbToast
            android:id="@+id/mt_close_error_toast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/mvb_spacing_400"
            android:visibility="gone"
            app:mtHasActionButton="false"
            app:mtHasCloseButton="false"
            app:mtToastLevel="level_danger" />

        <!-- Student Answer Popup — result mode, SHORT_ANSWER, click on ANSWERED cell -->
        <FrameLayout
            android:id="@+id/fl_student_answer_popup"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black_a35"
            android:visibility="gone">

            <com.google.android.material.card.MaterialCardView
                android:layout_width="@dimen/quiz_mvb_short_answer_popup_width"
                android:layout_height="@dimen/quiz_mvb_short_answer_popup_height"
                android:layout_gravity="center"
                app:cardBackgroundColor="@color/neutral_0"
                app:cardCornerRadius="@dimen/radius_800"
                app:cardElevation="@dimen/mvb_spacing_300">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:paddingTop="@dimen/mvb_spacing_400"
                    android:paddingBottom="@dimen/mvb_spacing_600"
                    android:paddingHorizontal="@dimen/mvb_spacing_400">

                    <!-- Answer text area with blue border -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_neutral0_radius800_line_violet500_border400"
                        android:clipToOutline="true">

                        <ScrollView
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:fillViewport="true">

                            <TextView
                                android:id="@+id/tv_popup_student_answer"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:fontFamily="sans-serif"
                                android:paddingHorizontal="@dimen/mvb_spacing_800"
                                android:paddingVertical="@dimen/mvb_spacing_600"
                                android:textColor="@color/neutral_900"
                                android:textSize="@dimen/quiz_mvb_text_popup_answer" />
                        </ScrollView>
                    </FrameLayout>

                    <!-- Bottom control bar -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/mvb_spacing_1200"
                        android:layout_marginTop="@dimen/mvb_spacing_600"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <!-- Show students' name toggle -->
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif-medium"
                            android:text="@string/quiz_mvb_show_students_name"
                            android:textColor="@color/neutral_900"
                            android:textSize="@dimen/quiz_mvb_text_sm" />

                        <androidx.appcompat.widget.SwitchCompat
                            android:id="@+id/sw_popup_show_students_name"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/mvb_spacing_200"
                            android:background="@null"
                            android:checked="true"
                            android:switchMinWidth="@dimen/mvb_spacing_1500"
                            android:thumb="@drawable/selector_mvb_audio_switch_thumb"
                            app:track="@drawable/selector_mvb_audio_switch_track" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <!-- < Prev -->
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_popup_prev"
                            android:layout_width="@dimen/mvb_spacing_1200"
                            android:layout_height="@dimen/mvb_spacing_1200"
                            android:clickable="true"
                            android:contentDescription="@string/quiz_mvb_short_answer_popup_prev_content_desc"
                            android:focusable="true"
                            android:padding="@dimen/mvb_spacing_300"
                            android:src="@drawable/ic_chevron_left_16"
                            app:tint="@color/neutral_900"
                            tools:ignore="UseAppTint" />

                        <!-- Student name chip -->
                        <TextView
                            android:id="@+id/tv_popup_student_name"
                            android:layout_width="wrap_content"
                            android:layout_height="@dimen/mvb_spacing_1200"
                            android:layout_marginHorizontal="@dimen/mvb_spacing_200"
                            android:background="@drawable/bg_neutral100_radius600"
                            android:fontFamily="sans-serif-medium"
                            android:gravity="center"
                            android:paddingHorizontal="@dimen/mvb_spacing_500"
                            android:textColor="@color/neutral_900"
                            android:textSize="@dimen/quiz_mvb_text_xl" />

                        <!-- > Next -->
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_popup_next"
                            android:layout_width="@dimen/mvb_spacing_1200"
                            android:layout_height="@dimen/mvb_spacing_1200"
                            android:clickable="true"
                            android:contentDescription="@string/quiz_mvb_short_answer_popup_next_content_desc"
                            android:focusable="true"
                            android:padding="@dimen/mvb_spacing_300"
                            android:src="@drawable/ic_chevron_right_16"
                            app:tint="@color/neutral_900"
                            tools:ignore="UseAppTint" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="0dp"
                            android:layout_weight="1" />

                        <!-- × Close -->
                        <androidx.appcompat.widget.AppCompatImageView
                            android:id="@+id/iv_popup_close"
                            android:layout_width="@dimen/mvb_spacing_1200"
                            android:layout_height="@dimen/mvb_spacing_1200"
                            android:clickable="true"
                            android:contentDescription="@string/quiz_mvb_short_answer_popup_close_content_desc"
                            android:focusable="true"
                            android:padding="@dimen/mvb_spacing_250"
                            android:src="@drawable/ic_close_64dp"
                            android:background="@drawable/ripple_neutral300_oval"
                            app:tint="@color/neutral_900"
                            tools:ignore="UseAppTint" />
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>
        </FrameLayout>

        <FrameLayout
            android:id="@+id/fl_close_loading_overlay"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black_a35"
            android:clickable="true"
            android:focusable="true"
            android:visibility="gone">

            <FrameLayout
                android:layout_width="@dimen/mvb_spacing_900"
                android:layout_height="@dimen/mvb_spacing_900"
                android:layout_gravity="center"
                android:background="@drawable/bg_neutral0_radius800"
                android:padding="@dimen/mvb_spacing_200">

                <com.airbnb.lottie.LottieAnimationView
                    android:id="@+id/lav_loading"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    app:lottie_autoPlay="false"
                    app:lottie_fileName="ani_loading.json"
                    app:lottie_loop="true" />
            </FrameLayout>
        </FrameLayout>

        <com.viewsonic.classswift.ui.widget.dialog.MvbSystemDialogView
            android:id="@+id/msdv_close_confirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

        <com.viewsonic.classswift.ui.widget.CSSnackbar
            android:id="@+id/cs_snackbar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/mvb_spacing_400"
            android:visibility="gone" />
    </FrameLayout>
</FrameLayout>
