<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_select_class"
    android:layout_width="match_parent"
    android:layout_height="45dp"
    android:background="@drawable/selector_window_select_org_item_bg"
    android:paddingStart="14.9dp"
    android:paddingTop="6.1dp"
    android:paddingEnd="12dp"
    android:paddingBottom="6dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_left"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_delete"
        app:layout_constraintHorizontal_bias="0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">
        
        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="16.7dp"
            android:layout_height="16.7dp"
            android:layout_marginEnd="4dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_class_sub_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/tv_class_name"
            tools:visibility="visible"
            tools:src="@drawable/ic_classlink" />

        <!-- 標題文字 -->
        <TextView
            android:id="@+id/tv_class_name"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:includeFontPadding="false"
            android:ellipsize="end"
            android:maxLength="50"
            android:maxLines="1"
            android:textColor="@drawable/selector_window_select_org_item_text"
            android:textSize="14.3sp"
            android:textStyle="bold"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toTopOf="@id/tv_class_sub_title"
            app:layout_constraintStart_toEndOf="@id/iv_icon"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="NewClass 1" />

        <TextView
            android:id="@+id/tv_class_sub_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="1.2dp"
            android:background="@drawable/selector_window_my_class_select_sub_text_bg"
            android:gravity="center"
            android:maxLength="50"
            android:maxLines="1"
            android:paddingHorizontal="3.6dp"
            android:paddingTop="1dp"
            android:paddingBottom="1dp"
            android:text="@string/my_class_status_ongoing"
            android:includeFontPadding="false"
            android:visibility="gone"
            android:textColor="@color/window_my_class_new_class_item_sub_text"
            android:textSize="8.39sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_class_name" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <ImageView
        android:id="@+id/iv_delete"
        android:layout_width="28dp"
        android:layout_height="28dp"
        android:src="@drawable/selector_my_class_delete"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/cl_left"
        app:layout_constraintTop_toTopOf="parent" />


</androidx.constraintlayout.widget.ConstraintLayout>
