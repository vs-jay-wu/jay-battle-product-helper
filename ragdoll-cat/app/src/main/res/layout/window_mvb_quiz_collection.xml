<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/mvb_spacing_400">

<androidx.constraintlayout.widget.ConstraintLayout
    android:id="@+id/ll_mqcw_shell_root"
    android:layout_width="@dimen/quiz_mvb_qc_window_width"
    android:layout_height="@dimen/quiz_mvb_qc_window_height"
    android:background="@drawable/bg_mvb_qc_window"
    android:clipToOutline="true"
    android:elevation="@dimen/mvb_spacing_200"
    android:outlineProvider="background">

    <!-- Header -->
    <LinearLayout
        android:id="@+id/ll_mqcw_header"
        android:layout_width="0dp"
        android:layout_height="@dimen/quiz_mvb_qc_window_header_height"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/mvb_spacing_400"
        android:paddingEnd="@dimen/mvb_spacing_300"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:layout_width="@dimen/quiz_mvb_qc_icon_lg"
            android:layout_height="@dimen/quiz_mvb_qc_icon_lg"
            android:contentDescription="@null"
            android:src="@drawable/ic_mvb_qc_collection" />

        <TextView
            android:id="@+id/tv_mqcw_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/mvb_spacing_300"
            android:layout_weight="1"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:text="@string/mvb_qc_window_title"
            android:textColor="@color/neutral_900"
            android:textSize="@dimen/quiz_mvb_text_md"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/iv_minimize_window"
            android:layout_width="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:layout_height="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:layout_marginEnd="@dimen/mvb_spacing_200"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:padding="@dimen/mvb_spacing_150"
            android:src="@drawable/ic_minus_32dp"
            tools:visibility="gone" />

        <ImageView
            android:id="@+id/iv_toolbar_bring_to_front"
            android:layout_width="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:layout_height="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:layout_marginEnd="@dimen/mvb_spacing_200"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:padding="@dimen/mvb_spacing_150"
            android:src="@drawable/ic_toolbar_bring_to_front_64dp"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/iv_close"
            android:layout_width="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:layout_height="@dimen/quiz_mvb_qc_toolbar_icon_size"
            android:background="?selectableItemBackgroundBorderless"
            android:clickable="true"
            android:contentDescription="@null"
            android:focusable="true"
            android:padding="@dimen/mvb_spacing_150"
            android:src="@drawable/ic_close_64dp"
            app:tint="@color/neutral_900" />
    </LinearLayout>

    <View
        android:id="@+id/v_mqcw_header_divider"
        android:layout_width="0dp"
        android:layout_height="@dimen/mvb_border_100"
        android:background="@color/color_E6E6E6"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_mqcw_header" />

    <!-- Sidemenu (folder list) -->
    <FrameLayout
        android:id="@+id/fl_mqcw_sidemenu"
        android:layout_width="@dimen/quiz_mvb_qc_sidemenu_width"
        android:layout_height="0dp"
        android:background="@drawable/bg_mvb_qc_sidemenu"
        android:paddingTop="@dimen/mvb_spacing_400"
        android:paddingBottom="@dimen/mvb_spacing_900"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/v_mqcw_header_divider">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_mqcw_folders"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:paddingStart="@dimen/mvb_spacing_300"
            android:paddingEnd="@dimen/mvb_spacing_300"
            tools:itemCount="6"
            tools:listitem="@layout/item_mvb_qc_folder"
            tools:orientation="vertical" />

        <com.viewsonic.classswift.ui.widget.MvbLoadingAnimation
            android:id="@+id/la_mqcw_folders_loading"
            android:layout_width="@dimen/quiz_mvb_qc_sidemenu_loading_size"
            android:layout_height="@dimen/quiz_mvb_qc_sidemenu_loading_size"
            android:layout_gravity="center"
            android:visibility="gone" />
    </FrameLayout>

    <View
        android:id="@+id/v_mqcw_sidemenu_divider"
        android:layout_width="@dimen/mvb_border_100"
        android:layout_height="0dp"
        android:background="@color/neutral_300"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/fl_mqcw_sidemenu"
        app:layout_constraintTop_toBottomOf="@id/v_mqcw_header_divider" />

    <!-- Breadcrumb navigator (Your folders > current folder) -->
    <LinearLayout
        android:id="@+id/ll_mqcw_breadcrumb"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/mvb_spacing_900"
        android:paddingTop="@dimen/mvb_spacing_400"
        android:paddingEnd="@dimen/mvb_spacing_900"
        android:paddingBottom="@dimen/mvb_spacing_300"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/v_mqcw_sidemenu_divider"
        app:layout_constraintTop_toBottomOf="@id/v_mqcw_header_divider">

        <ImageView
            android:layout_width="@dimen/quiz_mvb_qc_icon_xs"
            android:layout_height="@dimen/quiz_mvb_qc_icon_xs"
            android:contentDescription="@null"
            android:src="@drawable/ic_mvb_qc_folder"
            app:tint="@color/neutral_900" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/mvb_spacing_200"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:text="@string/mvb_qc_your_folders"
            android:textColor="@color/neutral_900"
            android:textSize="@dimen/quiz_mvb_text_sm" />

        <ImageView
            android:layout_width="@dimen/quiz_mvb_qc_icon_xs"
            android:layout_height="@dimen/quiz_mvb_qc_icon_xs"
            android:layout_marginStart="@dimen/mvb_spacing_300"
            android:contentDescription="@null"
            android:rotation="270"
            android:src="@drawable/ic_chevron_down"
            app:tint="@color/neutral_900" />

        <ImageView
            android:layout_width="@dimen/quiz_mvb_qc_icon_xs"
            android:layout_height="@dimen/quiz_mvb_qc_icon_xs"
            android:layout_marginStart="@dimen/mvb_spacing_300"
            android:contentDescription="@null"
            android:src="@drawable/ic_mvb_qc_folder"
            app:tint="@color/neutral_900" />

        <TextView
            android:id="@+id/tv_mqcw_breadcrumb_current"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="@dimen/mvb_spacing_200"
            android:layout_weight="1"
            android:ellipsize="end"
            android:fontFamily="sans-serif"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:textColor="@color/neutral_900"
            android:textSize="@dimen/quiz_mvb_text_sm"
            tools:text="Science Grade1" />
    </LinearLayout>

    <!-- Body container (quiz list / empty / error) -->
    <FrameLayout
        android:id="@+id/fl_mqcw_body"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/v_mqcw_sidemenu_divider"
        app:layout_constraintTop_toBottomOf="@id/ll_mqcw_breadcrumb">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_mqcw_quizzes"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false"
            android:overScrollMode="never"
            android:padding="@dimen/mvb_spacing_400"
            tools:itemCount="8"
            tools:listitem="@layout/item_mvb_qc_quiz"
            tools:spanCount="4" />

        <com.viewsonic.classswift.ui.widget.quizcollection.mvb.MvbQuizCollectionLoadingStateView
            android:id="@+id/cv_mqcw_loading_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="gone" />

        <com.viewsonic.classswift.ui.widget.quizcollection.mvb.MvbQuizCollectionEmptyStateView
            android:id="@+id/cv_mqcw_empty_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="gone" />

        <com.viewsonic.classswift.ui.widget.quizcollection.mvb.MvbQuizCollectionErrorStateView
            android:id="@+id/cv_mqcw_error_state"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:visibility="gone"
            tools:visibility="gone" />
    </FrameLayout>

    <!-- Detail container (visible when selectedQuiz != null; covers sidemenu+body).
         clickable+focusable so touches don't pass through to the quiz list cells underneath. -->
    <FrameLayout
        android:id="@+id/cv_mqcw_detail"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@color/neutral_0"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/v_mqcw_header_divider"
        tools:visibility="gone" />

    <!-- Dispatch result toast (system error / ongoing conflict) — bottom-center, danger level (matches MvbTrueFalseStartWindow pattern) -->
    <com.viewsonic.classswift.ui.widget.MvbToast
        android:id="@+id/mt_mqcw_toast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginBottom="@dimen/mvb_spacing_400"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:mtHasActionButton="false"
        app:mtHasCloseButton="false"
        app:mtToastLevel="level_danger"
        tools:visibility="gone" />
</androidx.constraintlayout.widget.ConstraintLayout>
</FrameLayout>
