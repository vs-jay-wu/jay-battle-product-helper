<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_select_class"
    android:layout_width="match_parent"
    android:layout_height="45.33dp"
    android:background="@drawable/bg_class_item_card"
    android:padding="10.67dp">

    <!-- Left: optional GC icon for roster classes -->
    <ImageView
        android:id="@+id/iv_icon"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginEnd="5.33dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:src="@drawable/ic_google_classroom"
        tools:visibility="visible" />

    <!-- Class name -->
    <TextView
        android:id="@+id/tv_class_name"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:ellipsize="end"
        android:fontFamily="sans-serif-medium"
        android:maxLines="1"
        android:textColor="@color/neutral_900"
        android:textSize="10.67sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toStartOf="@id/ll_actions"
        app:layout_constraintStart_toEndOf="@id/iv_icon"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="NewClass 1" />

    <!-- Right: ongoing badge (shown when lesson is in progress, hides rename/delete) -->
    <LinearLayout
        android:id="@+id/ll_ongoing_badge"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_red_pill"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="5.33dp"
        android:paddingEnd="5.33dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible">

        <ImageView
            android:layout_width="9.33dp"
            android:layout_height="9.33dp"
            android:layout_marginEnd="2.67dp"
            android:src="@drawable/ic_broadcast"
            app:tint="@android:color/white"
            tools:ignore="ContentDescription" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/my_class_status_ongoing"
            android:textColor="@android:color/white"
            android:textSize="8sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Right: rename + delete icons (hidden for roster/ongoing) -->
    <LinearLayout
        android:id="@+id/ll_actions"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="visible"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_rename"
            android:layout_width="26.67dp"
            android:layout_height="26.67dp"
            android:padding="8dp"
            android:src="@drawable/ic_pen_straight_line"
            tools:ignore="ContentDescription" />

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="26.67dp"
            android:layout_height="26.67dp"
            android:padding="8dp"
            android:src="@drawable/ic_trash_can"
            tools:ignore="ContentDescription" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
