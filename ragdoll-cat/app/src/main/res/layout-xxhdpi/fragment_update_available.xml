<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="252.6dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cs_ask_permission"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:paddingVertical="6.08dp"
            android:layout_marginTop="21.6dp"
            android:src="@drawable/ic_small_logo"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="@string/autoupdate_available"
            android:textAlignment="center"
            android:textColor="@color/cs_system_dialog_text_color"
            android:textFontWeight="600"
            android:textSize="14.4sp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_icon" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="@string/autoupdate_available_description"
            android:textAlignment="center"
            android:textColor="@color/cs_system_dialog_text_color"
            android:textFontWeight="400"
            android:textSize="12sp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_quit_app"
            android:layout_width="0dp"
            android:layout_height="28.44dp"
            android:layout_marginStart="20dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="21.6dp"
            app:lbRadius="4.8dp"
            app:lbText="@string/common_quit_app"
            app:lbTextSize="14sp"
            app:lbTextColor="@color/brand_blue"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintWidth_percent="0.4"
            app:lbBackgroundColor="@color/progressing_loading_white"
            app:lbBorderColor="@color/brand_blue"/>

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_update_now"
            android:layout_width="0dp"
            android:layout_height="28.44dp"
            android:layout_marginTop="16dp"
            android:layout_marginEnd="20dp"
            android:layout_marginBottom="21.6dp"
            app:lbRadius="4.8dp"
            app:lbTextSize="14sp"
            app:lbText="@string/autoupdate_update_now"
            app:lbTextColor="@color/progressing_loading_white"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:layout_constraintWidth_percent="0.4"
            app:lbBackgroundColor="@color/brand_blue"
            app:lbBorderColor="@color/transparent_color"/>

        <com.viewsonic.classswift.ui.widget.CSToast
            android:id="@+id/cst_toast"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="8dp"
            android:visibility="gone"
            app:cstText="@string/autoupdate_update_failed"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:successStatus="false"
            tools:visibility="visible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>