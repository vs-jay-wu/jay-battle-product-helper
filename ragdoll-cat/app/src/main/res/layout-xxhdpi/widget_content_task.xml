<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_edit_toolbar"
        android:layout_width="508dp"
        android:layout_height="28dp"
        android:visibility="invisible"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/btn_cancel_edit"
            android:layout_width="53.33dp"
            android:layout_height="23.33dp"
            android:background="@drawable/bg_neutral0_radius400_line_neutral450_border200"
            android:gravity="center"
            android:text="@string/common_cancel"
            android:textColor="@color/neutral_750"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/iv_delete"
            android:layout_width="29.66dp"
            android:layout_height="29.66dp"
            android:layout_marginStart="5.33dp"
            android:scaleType="center"
            android:src="@drawable/selector_push_respond_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/btn_cancel_edit"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_selected_count"
        android:layout_width="wrap_content"
        android:layout_height="20dp"
        android:layout_marginTop="4dp"
        android:textColor="@color/push_and_respond_selected_count_text_color"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="1 selected" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerview"
        android:layout_width="match_parent"
        android:layout_height="353dp"
        android:layout_marginTop="13.33dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/cl_edit_toolbar" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="13.33dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/recyclerview">

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_to_all"
            style="@style/DefaultButtonSelectWindow"
            android:layout_height="32dp"
            android:clickable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:lbBackgroundColor="@color/push_and_respond_button_enable_color"
            app:lbDisableBackgroundColor="@color/push_and_respond_button_disable_color"
            app:lbLoadingBackground="@color/push_and_respond_button_enable_color"
            app:lbProgressIndicatorColor="@color/progressing_loading_white"
            app:lbText="@string/push_and_respond_action_to_all"
            app:lbTextColor="@color/neutral_0"
            app:lbTextSize="16sp" />

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_custom_push"
            style="@style/DefaultButtonSelectWindow"
            android:layout_height="32dp"
            android:layout_marginEnd="5.33dp"
            android:clickable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@+id/cslb_to_all"
            app:layout_constraintTop_toTopOf="parent"
            app:lbAlertBorderColor="@color/push_and_respond_button_enable_color"
            app:lbAlertText="@string/common_cancel"
            app:lbAlertTextColor="@color/push_and_respond_button_enable_color"
            app:lbBackgroundColor="@color/neutral_0"
            app:lbBorderColor="@color/push_and_respond_button_enable_color"
            app:lbDisableBackgroundColor="@color/neutral_0"
            app:lbDisableBorderColor="@color/push_and_respond_button_disable_color"
            app:lbDisableTextColor="@color/push_and_respond_button_disable_color"
            app:lbLoadingBackground="@color/push_and_respond_button_enable_color"
            app:lbProgressIndicatorColor="@color/progressing_loading_white"
            app:lbText="@string/push_and_respond_action_custom_push"
            app:lbTextColor="@color/push_and_respond_button_enable_color"
            app:lbTextSize="16sp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>