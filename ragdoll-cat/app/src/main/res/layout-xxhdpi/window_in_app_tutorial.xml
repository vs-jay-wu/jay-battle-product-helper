<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_0">

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/gl_bottom_horizontal"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_bottom_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.9"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_bottom_bar"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:paddingHorizontal="21.33dp"
        app:layout_constraintTop_toBottomOf="@id/gl_bottom_horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_left_cta"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar.Bridge"
            android:text="@string/tutorial_actions_watch_again"
            android:textColor="@color/violet_700"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium"
            app:strokeColor="@color/violet_700"
            app:strokeWidth="1.06dp"
            app:cornerRadius="5.33dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"/>

        <com.viewsonic.classswift.ui.widget.inapptutorial.CSVideoGuideIndicator
            android:id="@+id/csvgi_video_guide_indicator"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            tool:visibility="visible"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_right_cta_negative"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:layout_marginRight="16dp"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar.Bridge"
            android:text="@string/tutorial_actions_back"
            android:textColor="@color/neutral_0"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium"
            android:visibility="gone"
            app:backgroundTint="@color/violet_700"
            app:cornerRadius="5.33dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toLeftOf="@id/mb_right_cta_positive"/>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/mb_right_cta_positive"
            style="@style/Widget.MaterialComponents.Button"
            android:layout_width="140dp"
            android:layout_height="48dp"
            android:theme="@style/Theme.MaterialComponents.DayNight.NoActionBar.Bridge"
            android:text="@string/tutorial_actions_get_started"
            android:textColor="@color/neutral_0"
            android:textSize="16sp"
            android:textAllCaps="false"
            android:includeFontPadding="false"
            android:fontFamily="sans-serif-medium"
            app:backgroundTint="@color/violet_700"
            app:cornerRadius="5.33dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.viewsonic.classswift.ui.widget.CSToast
        android:id="@+id/cst_error_toast"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:cstText="@string/tutorial_feedback_failed_toast_title"
        app:cstActionTitle="@string/toolbar_menu_settings_quit_app"
        app:successStatus="false"
        app:hasAction="true"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tool:visibility="visible"/>

</androidx.constraintlayout.widget.ConstraintLayout>