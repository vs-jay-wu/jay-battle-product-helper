<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_number"
        android:layout_width="25dp"
        android:layout_height="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintDimensionRatio="H,1:1"
        android:background="@drawable/bg_cs_blue_round_button"
        android:text="@string/quiz_option_number"
        android:textColor="@color/multiple_choice_options_text_blue"
        android:textSize="10sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_alphabet"
        android:layout_width="25dp"
        android:layout_height="0dp"
        android:stateListAnimator="@null"
        app:layout_constraintDimensionRatio="H,1:1"
        android:background="@drawable/bg_cs_transparent_round_button"
        android:text="@string/quiz_option_letter"
        android:textColor="@color/multiple_choice_options_text_gray"
        android:textSize="8sp"
        android:textStyle="bold"
        android:layout_marginStart="5dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@+id/button_number"/>

</merge>