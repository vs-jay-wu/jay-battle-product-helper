<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <ImageView
        android:id="@+id/view_indicator_1"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:src="@drawable/selector_video_guide_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/view_indicator_2"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/selector_video_guide_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_indicator_1"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/view_indicator_3"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/selector_video_guide_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_indicator_2"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/view_indicator_4"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/selector_video_guide_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_indicator_3"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/view_indicator_5"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginLeft="4dp"
        android:src="@drawable/selector_video_guide_indicator"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_indicator_4"
        tools:ignore="ContentDescription" />
</merge>
