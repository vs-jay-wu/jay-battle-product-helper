<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/mcv_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:theme="@style/Theme.MaterialComponents.Bridge"
    app:cardBackgroundColor="@color/color_F1FAEB"
    app:cardCornerRadius="@dimen/radius_400"
    app:cardElevation="0dp"
    app:strokeColor="@color/color_78CB3D"
    app:strokeWidth="1.33dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_number_and_name"
            android:layout_width="0dp"
            android:layout_height="48.6dp"
            android:background="@color/color_78CB3D"
            android:ellipsize="end"
            android:gravity="center"
            android:includeFontPadding="false"
            android:maxLines="1"
            android:paddingHorizontal="40dp"
            android:textColor="@color/neutral_0"
            android:textFontWeight="600"
            android:textSize="21.3sp"
            app:layout_constrainedWidth="true"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="15 米奇"
            tools:visibility="visible"/>

        <androidx.appcompat.widget.AppCompatTextView
            android:id="@+id/tv_short_answer_detail"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_margin="42.6dp"
            android:gravity="center"
            android:includeFontPadding="false"
            android:textColor="@color/color_2E3133"
            android:textFontWeight="400"
            android:textSize="21.3sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_number_and_name"
            tools:text="pleased with your situation and not hoping for change or improvement" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_close"
            android:layout_width="26.6dp"
            android:layout_height="26.6dp"
            android:layout_marginTop="10.6dp"
            android:layout_marginEnd="10.6dp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:srcCompat="@drawable/ic_close_rounded_96dp" />

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_left_arrow"
            android:layout_width="21.3dp"
            android:layout_height="21.3dp"
            android:layout_marginStart="10.6dp"
            app:srcCompat="@drawable/ic_left_arrow_64dp"
            app:tint="@color/selector_short_answer_detail_arrow_tint"
            app:layout_constraintTop_toBottomOf="@id/tv_number_and_name"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"/>

        <androidx.appcompat.widget.AppCompatImageView
            android:id="@+id/iv_right_arrow"
            android:layout_width="21.3dp"
            android:layout_height="21.3dp"
            android:layout_marginEnd="10.6dp"
            app:srcCompat="@drawable/ic_right_arrow_64dp"
            app:tint="@color/selector_short_answer_detail_arrow_tint"
            app:layout_constraintTop_toBottomOf="@id/tv_number_and_name"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>
        
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>