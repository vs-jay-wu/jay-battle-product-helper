<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="252.6dp"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_cs_ask_permission"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageView
            android:id="@+id/iv_big_icon"
            android:layout_width="120.66dp"
            android:layout_height="82.66dp"
            android:paddingHorizontal="17.33dp"
            android:layout_marginTop="36dp"
            android:src="@drawable/ic_large_logo"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tool:ignore="ContentDescription" />


        <com.google.android.material.progressindicator.CircularProgressIndicator
            android:id="@+id/cpi_loading_progress"
            android:layout_width="13dp"
            android:layout_height="13dp"
            android:layout_marginTop="12dp"
            android:indeterminate="true"
            app:indicatorColor="@color/brand_blue"
            app:indicatorInset="1dp"
            app:indicatorSize="13dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_big_icon"
            app:trackThickness="2dp" />

        <ImageView
            android:id="@+id/iv_icon"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:layout_marginTop="21.6dp"
            android:paddingVertical="6.08dp"
            android:src="@drawable/ic_small_logo"
            android:visibility="invisible"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tool:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="20dp"
            android:layout_marginTop="14dp"
            android:text="@string/region_not_supported_title"
            android:textAlignment="center"
            android:textColor="@color/neutral_900"
            android:textSize="14.4sp"
            android:textStyle="bold"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/iv_icon" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="21.6dp"
            android:layout_marginTop="14dp"
            android:text="@string/region_not_supported_message"
            android:textAlignment="center"
            android:textColor="@color/neutral_900"
            android:textFontWeight="400"
            android:textSize="12sp"
            android:visibility="invisible"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_title" />

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/csw_lb_got_it"
            android:layout_width="0dp"
            android:layout_height="28.44dp"
            android:layout_marginHorizontal="21.6dp"
            android:layout_marginTop="16dp"
            android:layout_marginBottom="18.2dp"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_description"
            app:lbBackgroundColor="@color/brand_blue"
            app:lbBorderColor="@color/transparent_color"
            app:lbRadius="4.8dp"
            app:lbText="@string/common_got_it"
            app:lbTextColor="@color/white"
            app:lbTextSize="14sp" />
    </androidx.constraintlayout.widget.ConstraintLayout>
</androidx.constraintlayout.widget.ConstraintLayout>