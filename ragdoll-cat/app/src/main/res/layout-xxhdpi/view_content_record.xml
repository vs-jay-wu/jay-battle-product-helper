<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_root"
    android:layout_width="161.33dp"
    android:layout_height="146.66dp"
    android:background="@drawable/bg_neutral0_radius800_line_neutral450_border400">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top_panel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginTop="5.33dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_seat_number"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_records_seat_number_enable"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/neutral_0"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2" />

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="78.66dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6.66dp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/records_name_enable_text_color"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_seat_number"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Andy Rubin Andy Rubin" />

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/cb_select"
            android:layout_width="14.16dp"
            android:layout_height="14.16dp"
            android:background="@null"
            android:button="@drawable/selector_records_check_box"
            android:checked="false"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.viewsonic.classswift.ui.widget.quiz.ImageUploadView
        android:id="@+id/iuv_thumbnail"
        android:layout_width="129.33dp"
        android:layout_height="68dp"
        android:layout_marginVertical="2.66dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:layout_marginBottom="5.33dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_submit_status"
            android:layout_width="wrap_content"
            android:layout_height="16.66dp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/records_not_submitted_text_color"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Not submitted" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/acb_add_point"
            android:layout_width="32dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_records_add_point"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/records_add_point"
            android:textColor="@color/neutral_0"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_add_point_animator"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginBottom="12dp"
        android:background="@color/transparent"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:padding="0dp"
        android:text="@string/records_add_point"
        android:textColor="@color/records_add_point_animator_text_color"
        android:textSize="13.33sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="+1" />

    <View
        android:id="@+id/view_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_white_a50_radius800_line_white_a50_boarder400"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>