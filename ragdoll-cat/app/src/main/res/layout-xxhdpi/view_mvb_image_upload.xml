<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_screenshot_image"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/mvb_spacing_100"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:srcCompat="@drawable/placeholder_1920x1080"
        tools:ignore="ContentDescription" />

    <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
        android:id="@+id/button_capture_again"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:paddingHorizontal="@dimen/mvb_spacing_600"
        android:layout_marginEnd="@dimen/mvb_spacing_250"
        android:layout_marginBottom="@dimen/mvb_spacing_250"
        android:clickable="true"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintHorizontal_weight="1"
        app:lbClickedBackgroundColor="@color/neutral_300"
        app:lbClickedBorderColor="@color/neutral_300"
        app:lbClickedTextColor="@color/neutral_900"
        app:lbClickedIconTint="@color/neutral_900"
        app:lbDisableBackgroundColor="@color/neutral_200"
        app:lbDisableBorderColor="@color/neutral_200"
        app:lbDisableTextColor="@color/neutral_500"
        app:lbDisableIconTint="@color/neutral_500"
        app:lbBackgroundColor="@color/neutral_100"
        app:lbBorderColor="@color/neutral_100"
        app:lbRadius="@dimen/mvb_radius_200"
        app:lbIconWidth="13.3dp"
        app:lbIconHeight="13.3dp"
        app:lbIconMarginEnd="@dimen/mvb_spacing_200"
        app:lbIconTint="@color/neutral_900"
        app:lbImgSrc="@drawable/ic_camera_viewfinder"
        app:lbText="@string/common_capture_again"
        app:lbTextColor="@color/neutral_900"
        app:lbTextSize="10.66sp"
        app:lbButtonState="enable" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_mask"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_margin="@dimen/mvb_spacing_100"
        android:visibility="invisible"
        app:srcCompat="@color/white_a80"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <LinearLayout
        android:id="@+id/ll_progress_bar_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="visible"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lav_loading"
            android:layout_width="32dp"
            android:layout_height="32dp"
            android:layout_gravity="center"
            app:lottie_autoPlay="true"
            app:lottie_fileName="ani_loading.json"
            app:lottie_loop="true" />
        
        <com.google.android.material.progressindicator.LinearProgressIndicator
            android:id="@+id/lpi_progress_bar"
            android:layout_width="200dp"
            android:layout_height="4dp"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:max="100"
            android:progress="40"
            app:indicatorColor="@color/vsds_sys_color_primary"
            app:trackColor="@color/vsds_sys_color_surface_200"
            app:trackCornerRadius="@dimen/mvb_radius_full"/>

        <TextView
            android:id="@+id/tv_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:textSize="10.66sp"
            android:textColor="@color/neutral_900"
            android:text="@string/mvb_question_edit_preparing_question_progress" />

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_upload_failed_container"
        android:visibility="gone"
        android:layout_gravity="center"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <ImageView
            android:id="@+id/iv_upload_failed"
            android:layout_width="21.33dp"
            android:layout_height="21.33dp"
            android:src="@drawable/ic_image_corners"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_upload_failed"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mvb_spacing_100"
            android:gravity="center_vertical"
            android:textSize="10.66sp"
            android:textColor="@color/neutral_900"
            android:text="@string/mvb_question_edit_failed_to_show_image"
            app:layout_constraintTop_toBottomOf="@id/iv_upload_failed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"/>

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_try_again"
            android:layout_width="108.66dp"
            android:layout_height="37.33dp"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:clickable="true"
            app:layout_constraintTop_toBottomOf="@id/tv_upload_failed"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:lbBackgroundColor="@color/vsds_sys_color_primary"
            app:lbBorderColor="@color/vsds_sys_color_primary"
            app:lbClickedBackgroundColor="@color/vsds_sys_color_primary"
            app:lbClickedBorderColor="@color/vsds_sys_color_primary"
            app:lbClickedIconTint="@color/neutral_0"
            app:lbClickedTextColor="@color/neutral_0"
            app:lbIconWidth="16dp"
            app:lbIconHeight="16dp"
            app:lbIconMarginEnd="@dimen/mvb_spacing_200"
            app:lbIconTint="@color/neutral_0"
            app:lbImgSrc="@drawable/ic_arrow_clockwise"
            app:lbText="@string/common_try_again"
            app:lbTextColor="@color/neutral_0"
            app:lbTextSize="12sp"
            app:lbButtonState="enable"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</merge>