<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="933.33dp"
    android:layout_height="569.33dp"
    android:background="@drawable/bg_cs_neutral_window">

    <ImageButton
        android:id="@+id/ib_close"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="10.6dp"
        android:background="@drawable/ic_close_64dp"
        android:backgroundTint="@color/bg_close_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:ignore="ContentDescription" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_toolbar_bring_to_front"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintRight_toLeftOf="@id/ib_close"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_toolbar_bring_to_front_64dp"
        app:tint="@color/bg_toolbar_bring_to_front" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_minimize_window"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintRight_toLeftOf="@id/ib_close"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_minus_32dp"
        app:tint="@color/bg_minimize_window" />

    <TextView
        android:id="@+id/tv_no_answer"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_marginTop="12dp"
        android:layout_marginEnd="13.33dp"
        android:text="@string/common_no_answer"
        android:textColor="@color/neutral_900"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ib_close" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_no_answer"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/neutral_450"
        app:cardCornerRadius="@dimen/radius_100"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintEnd_toStartOf="@id/tv_no_answer"
        app:layout_constraintTop_toTopOf="@id/tv_no_answer" />

    <TextView
        android:id="@+id/tv_incorrect"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_marginEnd="10.66dp"
        android:text="@string/common_incorrect"
        android:textColor="@color/neutral_900"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/cv_no_answer"
        app:layout_constraintTop_toTopOf="@id/tv_no_answer" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_incorrect"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/red_400"
        app:cardCornerRadius="@dimen/radius_100"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintEnd_toStartOf="@id/tv_incorrect"
        app:layout_constraintTop_toTopOf="@id/tv_no_answer" />

    <TextView
        android:id="@+id/tv_correct"
        android:layout_width="wrap_content"
        android:layout_height="16dp"
        android:layout_marginEnd="10.66dp"
        android:text="@string/common_correct"
        android:textColor="@color/neutral_900"
        android:textSize="12sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/cv_incorrect"
        app:layout_constraintTop_toTopOf="@id/tv_no_answer" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cv_correct"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginEnd="8dp"
        app:cardBackgroundColor="@color/green_500"
        app:cardCornerRadius="@dimen/radius_100"
        app:cardElevation="0dp"
        app:cardMaxElevation="0dp"
        app:cardUseCompatPadding="false"
        app:layout_constraintEnd_toStartOf="@id/tv_correct"
        app:layout_constraintTop_toTopOf="@id/tv_no_answer" />

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="26.66dp"
        android:layout_marginTop="26.66dp"
        android:text="@string/batch_quiz_title"
        android:textColor="@color/neutral_900"
        android:textSize="24sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_people"
        android:layout_width="21.6dp"
        android:layout_height="21.6dp"
        android:layout_marginStart="16dp"
        app:layout_constraintBottom_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toRightOf="@id/tv_title"
        app:layout_constraintTop_toTopOf="@id/tv_title"
        app:srcCompat="@drawable/ic_people" />

    <TextView
        android:id="@+id/tv_submitted_student_number"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="5.33dp"
        android:gravity="center_vertical"
        android:includeFontPadding="false"
        android:lineSpacingExtra="0dp"
        android:maxLines="1"
        android:textColor="@color/neutral_900"
        android:textFontWeight="400"
        android:textSize="16sp"
        app:layout_constraintBottom_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toRightOf="@id/iv_people"
        app:layout_constraintTop_toTopOf="@id/tv_title"
        tools:text="2" />

    <TextView
        android:id="@+id/tv_quiz"
        android:layout_width="120dp"
        android:layout_height="@dimen/batch_quiz_result_title_height"
        android:layout_marginStart="26.66dp"
        android:layout_marginTop="69.33dp"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="6.66dp"
        android:text="@string/quiz_title"
        android:textColor="@color/neutral_900"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/tv_bar_chart"
        android:layout_width="120dp"
        android:layout_height="wrap_content"
        android:gravity="start|center_vertical"
        android:paddingHorizontal="6.66dp"
        android:text="@string/bar_chart_title"
        android:textColor="@color/neutral_900"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintBottom_toTopOf="@id/cl_accuracy"
        app:layout_constraintStart_toStartOf="@id/tv_quiz"
        app:layout_constraintTop_toBottomOf="@id/tv_quiz" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_accuracy"
        android:layout_width="120dp"
        android:layout_height="@dimen/batch_quiz_result_title_with_scrollbar_height"
        android:layout_marginBottom="@dimen/batch_quiz_result_bottom_margin_for_scrollbar"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="@id/tv_quiz">

        <TextView
            android:id="@+id/tv_accuracy"
            android:layout_width="match_parent"
            android:layout_height="@dimen/batch_quiz_result_title_height"
            android:gravity="start|center_vertical"
            android:paddingHorizontal="6.66dp"
            android:text="@string/accuracy_title"
            android:textColor="@color/neutral_900"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_result_list"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fadeScrollbars="true"
        android:paddingBottom="@dimen/batch_quiz_result_scrollbar_padding"
        android:scrollbarDefaultDelayBeforeFade="500"
        android:scrollbarFadeDuration="300"
        android:scrollbarSize="4dp"
        android:scrollbarStyle="outsideOverlay"
        android:scrollbarThumbHorizontal="@drawable/shape_batch_quiz_scrollbar"
        android:scrollbars="horizontal"
        app:fastScrollEnabled="false"
        app:layout_constraintBottom_toBottomOf="@id/cl_accuracy"
        app:layout_constraintEnd_toEndOf="@id/tv_no_answer"
        app:layout_constraintStart_toEndOf="@id/tv_quiz"
        app:layout_constraintTop_toTopOf="@id/tv_quiz" />


    <LinearLayout
        android:id="@+id/ll_loading"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        app:layout_constraintBottom_toBottomOf="@id/rv_result_list"
        app:layout_constraintEnd_toEndOf="@id/rv_result_list"
        app:layout_constraintStart_toStartOf="@id/rv_result_list"
        app:layout_constraintTop_toTopOf="@id/rv_result_list">

        <com.airbnb.lottie.LottieAnimationView
            android:id="@+id/lav_loading_animation"
            android:layout_width="100dp"
            android:layout_height="100dp"
            app:lottie_autoPlay="true"
            app:lottie_fileName="animation_record_loading.json"
            app:lottie_loop="true" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center"
            android:text="@string/common_loading"
            android:textColor="@color/neutral_900"
            android:textSize="12sp" />
    </LinearLayout>

    <LinearLayout
        android:id="@+id/ll_retry"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:gravity="center"
        android:orientation="vertical"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="@id/rv_result_list"
        app:layout_constraintEnd_toEndOf="@id/rv_result_list"
        app:layout_constraintStart_toStartOf="@id/rv_result_list"
        app:layout_constraintTop_toTopOf="@id/rv_result_list"
        tools:visibility="gone">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/batch_quiz_failed_to_load"
            android:textColor="@color/neutral_900"
            android:textSize="16sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:layout_marginTop="5.33dp"
            android:gravity="center"
            android:text="@string/common_try_to_refresh_page"
            android:textColor="@color/neutral_900"
            android:textSize="12sp" />

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_refresh"
            android:layout_width="120dp"
            android:layout_height="32dp"
            android:layout_marginTop="16dp"
            app:lbBackgroundColor="@color/color_0A8CF0"
            app:lbLoadingBackground="@color/color_0A8CF0"
            app:lbProgressIndicatorColor="@color/neutral_0"
            app:lbText="@string/dialog_refresh_page_btn"
            app:lbTextColor="@color/neutral_0"
            app:lbTextSize="13.3sp" />

    </LinearLayout>

    <com.viewsonic.classswift.ui.widget.CSToast
        android:id="@+id/cst_toast"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:successStatus="false" />

    <View
        android:id="@+id/window_close_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_window_mask"
        android:clickable="true"
        android:visibility="gone" />

    <com.viewsonic.classswift.ui.widget.LoadingAnimation
        android:id="@+id/csw_loading_animation"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <View
        android:id="@+id/view_show_detail_mask"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:background="@drawable/bg_window_mask"
        android:clickable="true"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.viewsonic.classswift.ui.widget.batchquiz.CSBatchQuizDetailsResult
        android:id="@+id/csw_details_result"
        android:layout_width="900dp"
        android:layout_height="492.66dp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <com.viewsonic.classswift.ui.widget.NetworkDisconnectView
        android:id="@+id/view_network_disconnect"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardRadius="@dimen/radius_800"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>