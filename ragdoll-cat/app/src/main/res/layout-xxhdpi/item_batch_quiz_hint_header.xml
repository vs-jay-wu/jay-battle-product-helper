<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="26.66dp"
    android:layout_margin="5.33dp"
    android:background="@drawable/bg_neutral100_radius400">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_hint"
        android:layout_width="16dp"
        android:layout_height="16dp"
        android:layout_marginStart="8dp"
        app:srcCompat="@drawable/ic_hint"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"/>

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_hint"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginStart="2.66dp"
        android:layout_marginEnd="8dp"
        android:gravity="start|center_vertical"
        android:includeFontPadding="false"
        android:maxLines="1"
        android:ellipsize="end"
        android:text="@string/batch_quiz_hint"
        android:textColor="@color/neutral_900"
        android:textFontWeight="400"
        android:textSize="10.66sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_hint"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>