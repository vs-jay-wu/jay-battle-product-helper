<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:theme="@style/Theme.MaterialComponents.Bridge"
    android:background="@drawable/bg_neural0_radius600_line_neutral450_border400"
    android:layout_width="413dp"
    android:layout_height="wrap_content">
    
    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_maintenance"
        android:layout_width="207dp"
        android:layout_height="155dp"
        android:layout_marginTop="21.33dp"
        app:srcCompat="@drawable/ic_maintenance"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="6.66dp"
        android:layout_marginHorizontal="26.66dp"
        android:gravity="center"
        android:textColor="@color/color_2E3133"
        android:textSize="16sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/iv_maintenance"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="ClassSwift is Under Maintenance"/>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginHorizontal="26.66dp"
        android:gravity="center"
        android:textColor="@color/color_2E3133"
        android:textSize="13.3sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="We’ll be back on Sep. 22, 2025 (Tue) 17:00.
During maintenance, the ClassSwift application, ClassSwift Hub and account registration will be unavailable.
Thank you for your patience!"/>

    <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
        android:id="@+id/cslb_got_it"
        android:layout_width="0dp"
        android:layout_height="37.5dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="26.66dp"
        android:layout_marginHorizontal="26.66dp"
        android:clickable="true"
        app:layout_constraintTop_toBottomOf="@id/tv_description"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:lbRadius="@dimen/radius_400"
        app:lbProgressIndicatorColor="@color/white"
        app:lbBackgroundColor="@color/color_0A8CF0"
        app:lbBorderColor="@color/color_0A8CF0"
        app:lbText="@string/common_got_it"
        app:lbTextSize="16sp"
        app:lbTextColor="@color/white"
        app:lbDisableTextColor="@color/white"
        app:lbDisableBackgroundColor="@color/cs_button_bg_disable" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_close"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.7dp"
        android:layout_marginEnd="10.7dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/bg_close_button"
        app:srcCompat="@drawable/ic_close_64dp" />

</androidx.constraintlayout.widget.ConstraintLayout>