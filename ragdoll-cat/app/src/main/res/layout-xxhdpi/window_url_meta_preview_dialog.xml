<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@color/cs_system_dialog_mask_color"
    app:layout_constraintBottom_toBottomOf="parent"
    app:layout_constraintEnd_toEndOf="parent"
    app:layout_constraintStart_toStartOf="parent"
    app:layout_constraintTop_toTopOf="parent">

    <androidx.cardview.widget.CardView
        android:layout_width="372dp"
        android:layout_height="wrap_content"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:cardBackgroundColor="@color/cs_system_dialog_normal_background"
        app:cardCornerRadius="5.33dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="44dp"
                android:background="@color/cs_system_dialog_normal_background"
                android:gravity="center"
                android:padding="4dp"
                android:text="@string/common_link"
                android:textColor="@color/neutral_900"
                android:textFontWeight="600"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent="0.22"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="Link" />

            <View
                android:id="@+id/view_top_divider_line"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/cs_system_dialog_divide_color"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/tv_title" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_preview"
                android:layout_width="373.33dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="0dp"
                android:background="@color/neutral_0"
                android:minHeight="139.66dp"
                android:paddingBottom="30dp"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@+id/view_top_divider_line">

                <LinearLayout
                    android:id="@+id/ll_valid_link_hint"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="40dp"
                    android:layout_marginBottom="5.33dp"
                    android:orientation="horizontal"
                    app:layout_constraintBottom_toTopOf="@+id/et_url_input"
                    app:layout_constraintStart_toStartOf="@+id/et_url_input">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/aciv_icon_valid"
                        android:layout_width="13.33dp"
                        android:layout_height="13.33dp"
                        android:scaleType="centerCrop"
                        android:layout_gravity="center_vertical"
                        app:srcCompat="@drawable/ic_url_preview_valid_hint" />

                    <TextView
                        android:id="@+id/tv_valid_hint"
                        android:textColor="@color/url_preview_dialog_valid_hint_text_color"
                        android:layout_width="wrap_content"
                        android:textSize="10.66sp"
                        android:layout_marginStart="2.66dp"
                        android:text="@string/push_and_respond_error_msg_valid_url_hint"
                        android:layout_height="wrap_content"/>

                </LinearLayout>

                <androidx.appcompat.widget.AppCompatEditText
                    android:id="@+id/et_url_input"
                    android:layout_width="320dp"
                    android:layout_height="37.33dp"
                    android:layout_marginTop="62.33dp"
                    android:background="@drawable/bg_neutral0_radius400_line_neutral450_border200"
                    android:focusable="true"
                    android:focusableInTouchMode="true"
                    android:hint="@string/push_and_respond_hint_enter_link"
                    android:longClickable="true"
                    android:paddingHorizontal="10.66dp"
                    android:paddingVertical="6.66dp"
                    android:singleLine="true"
                    android:textColor="@color/url_preview_dialog_edittext_text_color"
                    android:textColorHint="@color/push_and_respond_url_input_hint_text_color"
                    android:textIsSelectable="true"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/cl_meta_preview"
                    android:layout_width="320dp"
                    android:layout_height="96.66dp"
                    android:layout_marginTop="5.33dp"
                    android:background="@drawable/bg_neutral0_radius200_line_neutral450_border200"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/et_url_input">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_link_thumbnail"
                        android:layout_width="110.66dp"
                        android:layout_height="80.66dp"
                        android:layout_marginStart="10.66dp"
                        android:layout_marginTop="8dp"
                        android:layout_marginBottom="8dp"
                        android:scaleType="centerCrop"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:srcCompat="@drawable/ic_link_task_placeholder" />

                    <TextView
                        android:id="@+id/tv_link_title"
                        android:layout_width="148.66dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxHeight="32dp"
                        android:maxLines="2"
                        android:text="ViewSonic ClassSwift ClassSwift ClassSwift ClassSwift"
                        android:textColor="@color/push_and_respond_link_task_title_text_color"
                        android:textSize="10.66sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                        app:layout_constraintTop_toTopOf="@+id/iv_link_thumbnail"
                        tools:text="ViewSonic ClassSwift ClassSwift ClassSwift ClassSwift" />

                    <TextView
                        android:id="@+id/tv_link_description"
                        android:layout_width="148.66dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:maxHeight="32dp"
                        android:maxLines="2"
                        android:text="ViewSonic ClassSwift ViewSonic ClassSwift ViewSonic ClassSwift"
                        android:textColor="@color/push_and_respond_link_task_description_text_color"
                        android:textSize="8sp"
                        app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                        app:layout_constraintTop_toBottomOf="@+id/tv_link_title"
                        tools:text="ViewSonic ClassSwift ViewSonic ClassSwift ViewSonic ClassSwift" />

                    <TextView
                        android:id="@+id/tv_link_url"
                        android:layout_width="148.66dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="8dp"
                        android:ellipsize="end"
                        android:gravity="center_vertical"
                        android:maxHeight="12dp"
                        android:maxLines="1"
                        android:text="ViewSonic ClassSwift ViewSonic ClassSwift ViewSonic ClassSwift"
                        android:textColor="@color/push_and_respond_url_preview_link_text_color"
                        android:textSize="8sp"
                        app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                        app:layout_constraintTop_toBottomOf="@+id/tv_link_description"
                        tools:text="https://viewsonic.com" />

                    <androidx.constraintlayout.widget.ConstraintLayout
                        android:id="@+id/cl_open_link"
                        android:layout_width="37.33dp"
                        android:layout_height="95.33dp"
                        android:layout_marginEnd="1.33dp"
                        android:background="@drawable/bg_url_open_link"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent">

                        <ImageView
                            android:layout_width="21.33dp"
                            android:layout_height="21.33dp"
                            android:layout_gravity="center"
                            android:src="@drawable/ic_url_meta_preview_open_link"
                            app:layout_constraintBottom_toBottomOf="parent"
                            app:layout_constraintEnd_toEndOf="parent"
                            app:layout_constraintStart_toStartOf="parent"
                            app:layout_constraintTop_toTopOf="parent" />

                    </androidx.constraintlayout.widget.ConstraintLayout>

                </androidx.constraintlayout.widget.ConstraintLayout>

            </androidx.constraintlayout.widget.ConstraintLayout>

            <View
                android:id="@+id/view_bottom_divider_line"
                android:layout_width="match_parent"
                android:layout_height="0.66dp"
                android:background="@color/cs_system_dialog_divide_color"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/cl_preview" />

            <View
                android:id="@+id/view_button_divider_line"
                android:layout_width="0.66dp"
                android:layout_height="0dp"
                android:background="@color/cs_system_dialog_divide_color"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_divider_line" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/bt_negative"
                android:layout_width="0dp"
                android:layout_height="37.33dp"
                android:background="@drawable/selector_system_dialog_button"
                android:padding="8dp"
                android:text="@string/common_cancel"
                android:textAllCaps="false"
                android:textColor="@color/url_preview_dialog_negative_text_color"
                android:textFontWeight="600"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/view_button_divider_line"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_divider_line"
                tools:text="@string/common_cancel" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/cpi_negative"
                android:layout_width="0dp"
                android:layout_height="37.33dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/brand_blue"
                app:indicatorSize="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1.01"
                app:layout_constraintHeight_percent=".12"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintRight_toLeftOf="@id/view_button_divider_line"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_divider_line"
                app:trackThickness="2dp"
                tools:visibility="visible" />

            <androidx.appcompat.widget.AppCompatButton
                android:id="@+id/acb_positive"
                android:layout_width="0dp"
                android:layout_height="37.33dp"
                android:background="@drawable/selector_system_dialog_button"
                android:padding="8dp"
                android:text="@string/common_confirm"
                android:textAllCaps="false"
                android:textColor="@color/brand_blue"
                android:textFontWeight="600"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/view_button_divider_line"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_divider_line"
                tools:text="@string/common_confirm" />

            <com.google.android.material.progressindicator.CircularProgressIndicator
                android:id="@+id/cpi_positive"
                android:layout_width="0dp"
                android:layout_height="37.33dp"
                android:indeterminate="true"
                android:visibility="gone"
                app:indicatorColor="@color/brand_blue"
                app:indicatorSize="24dp"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintDimensionRatio="1:1.01"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintHeight_percent=".12"
                app:layout_constraintStart_toEndOf="@id/view_button_divider_line"
                app:layout_constraintTop_toBottomOf="@id/view_bottom_divider_line"
                app:trackThickness="2dp"
                tools:visibility="visible" />
        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</androidx.constraintlayout.widget.ConstraintLayout>