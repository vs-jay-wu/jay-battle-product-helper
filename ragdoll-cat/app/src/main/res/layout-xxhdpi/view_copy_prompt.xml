<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:gravity="center">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_icon"
        android:layout_marginTop="2.7dp"
        android:layout_width="7.6dp"
        android:layout_height="7.dp"
        app:srcCompat="@drawable/ic_top_polygon"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent"/>

    <TextView
        android:id="@+id/tv_prompt"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="-1dp"
        android:paddingVertical="4dp"
        android:paddingHorizontal="6.7dp"
        android:background="@drawable/bg_solid_rounded_3dp"
        android:backgroundTint="@color/color_005FBD"
        android:textSize="12sp"
        android:textColor="@color/white"
        android:text="@string/join_class_copy_success"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/iv_icon"
        app:layout_constraintTop_toTopOf="parent" />
</LinearLayout>