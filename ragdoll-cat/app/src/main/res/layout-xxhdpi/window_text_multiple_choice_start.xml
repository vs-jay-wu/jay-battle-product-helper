<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="955dp"
    android:layout_height="515dp"
    android:background="@drawable/bg_cs_window"
    tools:ignore="ContentDescription">

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_close"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="10.6dp"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_close_64dp"
        android:background="@drawable/ripple_neutral300_oval" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_toolbar_bring_to_front"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintRight_toLeftOf="@id/iv_close"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_toolbar_bring_to_front_64dp"
        android:background="@drawable/ripple_neutral300_oval"
        app:tint="@color/bg_toolbar_bring_to_front" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_minimize_window"
        android:layout_width="21.3dp"
        android:layout_height="21.3dp"
        android:layout_marginTop="10.6dp"
        android:layout_marginEnd="8dp"
        app:layout_constraintRight_toLeftOf="@id/iv_close"
        app:layout_constraintTop_toTopOf="parent"
        app:srcCompat="@drawable/ic_minus_32dp"
        android:background="@drawable/ripple_neutral300_oval"
        app:tint="@color/bg_minimize_window" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_start_quiz_left_container"
        android:layout_width="355dp"
        android:layout_height="455dp"
        android:layout_marginVertical="30dp"
        android:layout_marginStart="30dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_window_title_container"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginEnd="35dp"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="@+id/fsv_scroll_view"
            app:layout_constraintTop_toTopOf="parent">

            <!-- 題型名稱 -->
            <TextView
                android:id="@+id/tv_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif-light"
                android:text="@string/window_title_multiple_choice"
                android:textColor="@color/window_edit_quiz_title"
                android:textSize="16sp"
                android:textStyle="bold"
                app:layout_constraintLeft_toLeftOf="parent"
                app:layout_constraintTop_toTopOf="parent" />

            <!-- 測驗中 label - 單選題/多選題 -->
            <TextView
                android:id="@+id/tv_choice_type_quizzing"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:background="@drawable/bg_cs_blue_round_button"
                android:paddingHorizontal="@dimen/margin_1"
                android:paddingVertical="@dimen/margin_3"
                android:textColor="@color/multiple_choice_options_text_blue"
                android:textSize="12sp"
                android:visibility="invisible"
                app:layout_constraintBottom_toBottomOf="@+id/tv_title"
                app:layout_constraintStart_toEndOf="@+id/tv_title"
                app:layout_constraintTop_toTopOf="@+id/tv_title"
                tools:text="@string/quiz_types_multiple_choice_single_answer" />

            <!-- 測驗後 label - 單選題/多選題 -->
            <TextView
                android:id="@+id/tv_choice_type_disclose_answer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/margin_8"
                android:background="@drawable/bg_cs_blue_round_button"
                android:paddingHorizontal="@dimen/margin_5"
                android:paddingVertical="@dimen/margin_3"
                android:textColor="@color/multiple_choice_options_text_blue"
                android:textSize="12sp"
                android:visibility="gone"
                app:layout_constraintStart_toStartOf="@+id/tv_title"
                app:layout_constraintTop_toBottomOf="@+id/tv_title"
                tools:text="@string/quiz_types_multiple_choice_single_answer" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <!-- 碼錶 -->
        <com.viewsonic.classswift.ui.widget.quiz.Stopwatch
            android:id="@+id/cs_stopwatch"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:layout_constraintBottom_toBottomOf="@+id/cl_window_title_container"
            app:layout_constraintEnd_toEndOf="@+id/cl_window_title_container"
            app:layout_constraintTop_toTopOf="@+id/cl_window_title_container" />

        <!-- FastScrollView -->
        <com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView
            android:id="@+id/fsv_scroll_view"
            android:layout_width="0dp"
            android:layout_height="0dp"
            android:layout_marginBottom="16dp"
            app:layout_constraintBottom_toTopOf="@id/barrier_quiz_action_buttons_top"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/cl_window_title_container">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:id="@+id/cl_scroll_container"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingEnd="30dp"
                android:paddingBottom="75dp">

                <androidx.appcompat.widget.AppCompatTextView
                    android:id="@+id/tv_quiz_content"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.66dp"
                    android:background="@drawable/bg_neutral0_radius400"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:padding="10.66dp"
                    android:textColor="@color/neutral_900"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    tools:text="Which statement below is sometimes used by historians to refer to the time period of the Tang Dynasty?" />

                <com.viewsonic.classswift.ui.widget.KatexView
                    android:id="@+id/cskv_quiz_content"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.66dp"
                    android:background="@drawable/bg_neutral0_radius400"
                    android:gravity="start|center_vertical"
                    android:includeFontPadding="false"
                    android:padding="10.66dp"
                    android:textColor="@color/neutral_900"
                    android:textSize="16sp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <androidx.constraintlayout.widget.Barrier
                    android:id="@+id/barrier_quiz_content_bottom"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    app:barrierDirection="bottom"
                    app:constraint_referenced_ids="tv_quiz_content,cskv_quiz_content" />

                <com.viewsonic.classswift.ui.widget.quizcollection.CSTextQuizOptionsPanel
                    android:id="@+id/cstqop_options_panel"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.6dp"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@+id/barrier_quiz_content_bottom"
                    tools:visibility="gone" />

                <com.viewsonic.classswift.ui.widget.quiz.ClassSwiftAnswerOptionInfoView
                    android:id="@+id/cs_answer_option_info"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="10.6dp"
                    android:visibility="gone"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/cstqop_options_panel"
                    tools:visibility="visible" />

            </androidx.constraintlayout.widget.ConstraintLayout>
        </com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView>

        <androidx.constraintlayout.widget.Barrier
            android:id="@+id/barrier_quiz_action_buttons_top"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            app:barrierDirection="top"
            app:constraint_referenced_ids="cslb_end_quiz,cslb_disclose_answer" />

        <!-- 結束測驗 button -->
        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_end_quiz"
            android:layout_width="160dp"
            android:layout_height="37.5dp"
            android:layout_marginEnd="35dp"
            android:clickable="true"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/fsv_scroll_view"
            app:layout_constraintStart_toStartOf="@+id/fsv_scroll_view"
            app:lbBackgroundColor="@color/white"
            app:lbBorderColor="@color/window_start_quiz_button_end_quiz_border"
            app:lbClickedBackgroundColor="@color/window_start_quiz_button_end_quiz_alert_bg"
            app:lbClickedBorderColor="@color/window_start_quiz_button_end_quiz_alert_bg"
            app:lbClickedTextColor="@color/white"
            app:lbLoadingBackground="@color/white"
            app:lbLoadingBorderColor="@color/window_start_quiz_button_end_quiz_alert_bg"
            app:lbProgressIndicatorColor="@color/window_start_quiz_button_end_quiz_alert_bg"
            app:lbText="@string/quiz_action_end_quiz"
            app:lbTextColor="@color/window_start_quiz_button_end_quiz_text"
            app:lbTextSize="14sp"
            tools:visibility="visible" />

        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_disclose_answer"
            android:layout_width="200dp"
            android:layout_height="37.5dp"
            android:layout_marginEnd="35dp"
            android:clickable="true"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="@+id/fsv_scroll_view"
            app:layout_constraintStart_toStartOf="@+id/fsv_scroll_view"
            app:lbBackgroundColor="@color/window_quizzing_disclose_button_bg"
            app:lbDisableBackgroundColor="@color/window_quizzing_disclose_button_bg_disable"
            app:lbLoadingBackground="@color/window_quizzing_disclose_button_loading_bg"
            app:lbProgressIndicatorColor="@color/progressing_loading_white"
            app:lbText="@string/disclose_the_set_answer"
            app:lbTextColor="@color/window_quizzing_disclose_button_text"
            app:lbTextSize="14sp" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <View
        android:id="@+id/view_divider"
        android:layout_width="8dp"
        android:layout_height="0dp"
        android:layout_marginVertical="1dp"
        android:background="@drawable/bg_gradient_divider"
        android:clickable="false"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@+id/cl_start_quiz_left_container"
        app:layout_constraintRight_toLeftOf="@+id/cl_start_quiz_right_container"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_start_quiz_right_container"
        android:layout_width="521.33dp"
        android:layout_height="0dp"
        android:layout_marginStart="30dp"
        android:layout_marginTop="30dp"
        android:layout_marginEnd="10dp"
        android:layout_marginBottom="1dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_divider"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_result_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10.66dp"
            android:text="@string/quiz_info_results"
            android:textColor="@color/window_edit_quiz_title"
            android:textSize="28sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- eye button -->
        <ToggleButton
            android:id="@+id/button_eye"
            android:layout_width="30dp"
            android:layout_height="30dp"
            android:layout_marginStart="5dp"
            android:background="@drawable/selector_quiz_result_eye"
            android:checked="false"
            android:textOff=""
            android:textOn=""
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="@+id/tv_result_title"
            app:layout_constraintStart_toEndOf="@+id/tv_result_title"
            app:layout_constraintTop_toTopOf="@+id/tv_result_title" />

        <LinearLayout
            android:id="@+id/ll_random_draw"
            android:layout_width="wrap_content"
            android:layout_height="30dp"
            android:layout_marginStart="5.33dp"
            android:background="@drawable/bg_button_quiz_random_draw"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:visibility="invisible"
            app:layout_constraintBottom_toBottomOf="@+id/button_eye"
            app:layout_constraintStart_toEndOf="@+id/button_eye"
            app:layout_constraintTop_toTopOf="@+id/button_eye">

            <androidx.appcompat.widget.AppCompatImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginStart="5.33dp"
                android:src="@drawable/ic_random_draw" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginEnd="8dp"
                android:text="@string/toolbar_menu_interaction_random_draw"
                android:textColor="@color/neutral_900"
                android:textFontWeight="600"
                android:textSize="12sp" />
        </LinearLayout>

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_answer_result_list"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:paddingHorizontal="10.66dp"
            app:fastScrollEnabled="true"
            app:fastScrollHorizontalThumbDrawable="@drawable/selector_student_list_scroll_thumb"
            app:fastScrollHorizontalTrackDrawable="@drawable/selector_student_list_scroll_track"
            app:fastScrollVerticalThumbDrawable="@drawable/selector_student_list_scroll_thumb"
            app:fastScrollVerticalTrackDrawable="@drawable/selector_student_list_scroll_track"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_result_title" />

        <!-- Overview 正確/錯誤/未作答人數 component -->
        <com.viewsonic.classswift.ui.widget.quiz.MultipleChoiceQuizResultsOverview
            android:id="@+id/cs_multiple_choice_quiz_results_overview"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="10.66dp"
            android:layout_marginTop="16dp"
            android:visibility="gone"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tv_result_title" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.viewsonic.classswift.ui.widget.CSToast
        android:id="@+id/cst_toast"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:successStatus="false"
        tools:visibility="visible" />

    <View
        android:id="@+id/view_close_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_window_mask"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.viewsonic.classswift.ui.widget.LoadingAnimation
        android:id="@+id/cs_loading_animation"
        android:layout_width="45dp"
        android:layout_height="45dp"
        android:layout_gravity="center"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.viewsonic.classswift.ui.widget.quiz.RandomDrawWidget
        android:id="@+id/widget_random_draw"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:hasCorrectAnswer="true"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <com.viewsonic.classswift.ui.widget.NetworkDisconnectView
        android:id="@+id/view_network_disconnect"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:visibility="gone"
        app:cardRadius="@dimen/radius_800"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
