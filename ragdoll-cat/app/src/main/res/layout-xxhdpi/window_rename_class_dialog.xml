<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/color_a64_000000">

    <androidx.cardview.widget.CardView
        android:layout_width="244dp"
        android:layout_height="wrap_content"
        android:layout_gravity="center"
        app:cardBackgroundColor="@color/white"
        app:cardCornerRadius="16dp"
        app:cardElevation="10.67dp">

        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <!-- state-layer: padding 16dp -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- body: py=16dp, min-h=53.33dp -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:minHeight="53.33dp"
                    android:orientation="vertical"
                    android:paddingTop="16dp"
                    android:paddingBottom="16dp">

                    <!-- Title row -->
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:gravity="center_vertical"
                        android:orientation="horizontal">

                        <ImageView
                            android:id="@+id/iv_title_icon"
                            android:layout_width="16dp"
                            android:layout_height="16dp"
                            android:src="@drawable/ic_pen_straight_line"
                            tools:ignore="ContentDescription" />

                        <TextView
                            android:id="@+id/tv_title"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="5.33dp"
                            android:fontFamily="sans-serif"
                            android:text="@string/my_class_rename_dialog_title"
                            android:textColor="@color/neutral_900"
                            android:textSize="13.33sp"
                            android:textStyle="bold" />
                    </LinearLayout>

                    <!-- Input field with clear button -->
                    <FrameLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="5.33dp">

                        <EditText
                            android:id="@+id/et_class_name"
                            android:layout_width="match_parent"
                            android:layout_height="26.67dp"
                            android:background="@drawable/bg_rename_input"
                            android:fontFamily="sans-serif"
                            android:imeOptions="actionDone"
                            android:inputType="text"
                            android:maxLength="50"
                            android:maxLines="1"
                            android:paddingStart="8dp"
                            android:paddingEnd="26.67dp"
                            android:textColor="@color/neutral_900"
                            android:textColorHint="@color/color_999999"
                            android:textSize="9.33sp"
                            tools:text="Default Class" />

                        <ImageView
                            android:id="@+id/iv_clear"
                            android:layout_width="26.67dp"
                            android:layout_height="26.67dp"
                            android:layout_gravity="end|center_vertical"
                            android:padding="8dp"
                            android:src="@drawable/ic_cross"
                            app:tint="@color/neutral_650"
                            tools:ignore="ContentDescription" />
                    </FrameLayout>

                    <!-- Error message (hidden by default) -->
                    <TextView
                        android:id="@+id/tv_error"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="2.67dp"
                        android:drawableStart="@drawable/ic_error_circle"
                        android:drawablePadding="2.67dp"
                        android:fontFamily="sans-serif"
                        android:text="@string/my_class_rename_error_empty"
                        android:textColor="@color/color_DC2626"
                        android:textSize="8sp"
                        android:visibility="gone"
                        tools:visibility="visible" />

                </LinearLayout>

                <!-- actions: pt=10.67dp -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="end|center_vertical"
                    android:orientation="horizontal"
                    android:paddingTop="10.67dp">

                    <TextView
                        android:id="@+id/tv_cancel"
                        android:layout_width="wrap_content"
                        android:layout_height="26.67dp"
                        android:layout_marginEnd="16dp"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingStart="10.67dp"
                        android:paddingEnd="10.67dp"
                        android:text="@string/common_cancel"
                        android:textColor="@color/neutral_900"
                        android:textSize="9.33sp" />

                    <TextView
                        android:id="@+id/tv_rename"
                        android:layout_width="wrap_content"
                        android:layout_height="26.67dp"
                        android:background="@drawable/bg_blue_radius400"
                        android:fontFamily="sans-serif-medium"
                        android:gravity="center"
                        android:paddingStart="10.67dp"
                        android:paddingEnd="10.67dp"
                        android:text="@string/my_class_action_rename"
                        android:textColor="@color/white"
                        android:textSize="9.33sp" />

                </LinearLayout>

            </LinearLayout>

            <!-- Close button: absolute right=16dp top=5.33dp from card edge -->
            <ImageButton
                android:id="@+id/button_close"
                android:layout_width="21.33dp"
                android:layout_height="21.33dp"
                android:layout_gravity="end"
                android:layout_marginTop="5.33dp"
                android:layout_marginEnd="16dp"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:padding="5.33dp"
                android:scaleType="fitCenter"
                android:src="@drawable/ic_cross"
                tools:ignore="ContentDescription" />

        </FrameLayout>
    </androidx.cardview.widget.CardView>

</FrameLayout>
