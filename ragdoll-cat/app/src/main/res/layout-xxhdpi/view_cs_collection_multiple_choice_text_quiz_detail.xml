<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_neutral0_radius800_line_neutral_500_border200"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <TextView
        android:id="@+id/tv_quiz_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10.66dp"
        android:includeFontPadding="false"
        android:textColor="@color/neutral_750"
        android:textSize="13.33sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/tv_quiz_type_option"
        app:layout_constraintBottom_toBottomOf="@id/tv_quiz_type_option"
        app:layout_constraintEnd_toStartOf="@id/view_vertical_divider"
        tools:text="History" />

    <View
        android:id="@+id/view_vertical_divider"
        android:layout_width="1dp"
        android:layout_height="12dp"
        android:layout_marginEnd="10.66dp"
        android:background="@color/neutral_750"
        app:layout_constraintTop_toTopOf="@id/tv_quiz_type_option"
        app:layout_constraintBottom_toBottomOf="@id/tv_quiz_type_option"
        app:layout_constraintEnd_toStartOf="@id/tv_quiz_type" />

    <TextView
        android:id="@+id/tv_quiz_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="10.66dp"
        android:includeFontPadding="false"
        android:text="@string/quiz_types_multiple_choice"
        android:textColor="@color/neutral_750"
        android:textSize="13.33sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="@id/tv_quiz_type_option"
        app:layout_constraintBottom_toBottomOf="@id/tv_quiz_type_option"
        app:layout_constraintEnd_toStartOf="@id/tv_quiz_type_option"
        tools:visibility="visible" />

    <TextView
        android:id="@+id/tv_quiz_type_option"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="26.66dp"
        android:layout_marginEnd="20dp"
        android:background="@drawable/bg_neutral200_radius200"
        android:includeFontPadding="false"
        android:paddingHorizontal="6.66dp"
        android:paddingVertical="3.16dp"
        android:textSize="12sp"
        android:textStyle="bold"
        android:textColor="@color/neutral_750"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="@string/quiz_types_multiple_choice_single_answer"
        tools:visibility="visible"/>

    <com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView
        android:id="@+id/fsv_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_quiz_tag"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48.66dp">

            <TextView
                android:id="@+id/tv_quiz_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                android:includeFontPadding="false"
                android:textColor="@color/neutral_900"
                android:textSize="18.66sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="What was the Catholic Church's practice of selling indulgences as a way to raise money and weaken its authority? "
                tools:visibility="visible" />

            <com.viewsonic.classswift.ui.widget.KatexView
                android:id="@+id/cskv_quiz_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                android:includeFontPadding="false"
                android:textColor="@color/neutral_900"
                android:textSize="18.66sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier_quiz_content_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tv_quiz_content,cskv_quiz_content" />

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_1"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/barrier_quiz_content_bottom"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_2"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/csctqov_option_1"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_3"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/csctqov_option_2"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_4"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/csctqov_option_3"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_5"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/csctqov_option_4"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <com.viewsonic.classswift.ui.widget.quizcollection.CSCollectionTextQuizOptionView
                android:id="@+id/csctqov_option_6"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                app:layout_constraintTop_toBottomOf="@id/csctqov_option_5"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView>

</merge>