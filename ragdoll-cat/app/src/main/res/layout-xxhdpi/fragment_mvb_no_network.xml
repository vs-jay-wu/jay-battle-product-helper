<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    android:clipToPadding="false"
    android:paddingStart="16dp"
    android:paddingTop="26.67dp"
    android:paddingEnd="16dp"
    android:paddingBottom="26.67dp">

    <!-- X close button (top-right, 8dp from panel corner via translation) -->
    <ImageButton
        android:id="@+id/ib_close"
        android:layout_width="26.67dp"
        android:layout_height="26.67dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:padding="8dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_close_64dp"
        android:translationX="10.67dp"
        android:translationY="-21.33dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="@color/neutral_900"
        tools:ignore="ContentDescription" />

    <!-- Title: "Welcome to ClassSwift" -->
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/mvb_my_class_welcome_title"
        android:textColor="@color/neutral_900"
        android:textSize="18.67sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <!-- Subtitle row: CS icon + "Select or create a class to join" -->
    <ImageView
        android:id="@+id/iv_class_swift_icon"
        android:layout_width="13.33dp"
        android:layout_height="13.33dp"
        android:src="@drawable/ic_select_class_header"
        app:layout_constraintBottom_toBottomOf="@id/tv_subtitle"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="@id/tv_subtitle"
        tools:ignore="ContentDescription" />

    <TextView
        android:id="@+id/tv_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:layout_marginTop="10.67dp"
        android:text="@string/mvb_my_class_subtitle"
        android:textColor="@color/neutral_900"
        android:textSize="9.33sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_class_swift_icon"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        tools:ignore="SmallSp" />

    <!-- Error -->
    <ImageView
        android:id="@+id/iv_maintenance"
        android:layout_width="100dp"
        android:layout_height="100dp"
        android:scaleType="fitCenter"
        android:src="@drawable/ic_error"
        app:layout_constraintBottom_toTopOf="@id/ll_banner"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_subtitle"
        tools:ignore="ContentDescription" />

    <!-- Warning banner -->
    <LinearLayout
        android:id="@+id/ll_banner"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_banner_danger"
        android:gravity="top"
        android:orientation="horizontal"
        android:paddingStart="10.67dp"
        android:paddingTop="5.33dp"
        android:paddingEnd="10.67dp"
        android:paddingBottom="5.33dp"
        app:layout_constraintBottom_toTopOf="@id/ll_bottom_buttons"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <ImageView
            android:layout_width="13.33dp"
            android:layout_height="13.33dp"
            android:layout_marginEnd="5.33dp"
            android:contentDescription="@null"
            android:src="@drawable/ic_network_disconnect_black"
            tools:ignore="ContentDescription" />

        <TextView
            android:id="@+id/tv_description"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="@string/mvb_activate_error_description"
            android:textColor="@color/neutral_900"
            android:textSize="9.33sp"
            tools:text="Something went wrong, please check your internet status and try again later." />
    </LinearLayout>

    <!-- Bottom buttons row -->
    <LinearLayout
        android:id="@+id/ll_bottom_buttons"
        android:layout_width="0dp"
        android:layout_height="32dp"
        android:orientation="horizontal"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <!-- Exit ClassSwift button (outline, 50%) -->
        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/button_exit"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginEnd="5.33dp"
            android:layout_weight="1"
            android:clickable="true"
            app:lbBackgroundColor="@color/white"
            app:lbBorderColor="@color/window_select_org_right_button_bg_disable"
            app:lbRadius="5.33dp"
            app:lbText="@string/mvb_my_class_action_exit"
            app:lbTextColor="@color/neutral_900"
            app:lbTextSize="10.67sp" />

        <!-- Enter Class button (filled blue, 50%) -->
        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/button_enter_class"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_marginStart="5.33dp"
            android:layout_weight="1"
            android:clickable="true"
            app:lbBackgroundColor="@color/window_select_org_right_button_bg"
            app:lbDisableBackgroundColor="@color/window_select_org_right_button_bg_disable"
            app:lbLoadingBackground="@color/window_select_org_right_button_bg"
            app:lbProgressIndicatorColor="@color/progressing_loading_white"
            app:lbRadius="5.33dp"
            app:lbText="@string/my_class_action_enter_class"
            app:lbTextColor="@color/window_select_org_right_button_text"
            app:lbTextSize="10.67sp" />
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>