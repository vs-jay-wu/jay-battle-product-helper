<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tool="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <ImageView
        android:id="@+id/iv_background"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:src="@drawable/bg_in_app_tutorial_complete"
        android:scaleType="fitXY"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_top_horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        app:layout_constraintGuide_percent="0.38"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_left_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.6"/>

    <androidx.constraintlayout.widget.Guideline
        android:id="@+id/gl_right_vertical"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        app:layout_constraintGuide_percent="0.94"/>
    
    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="@string/tutorial_completion_title"
        android:textColor="@color/neutral_0"
        android:textSize="40sp"
        android:textStyle="bold"
        app:layout_constraintTop_toBottomOf="@id/gl_top_horizontal"
        app:layout_constraintLeft_toLeftOf="@id/gl_left_vertical"
        app:layout_constraintRight_toRightOf="@id/gl_right_vertical"/>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="40dp"
        android:layout_marginHorizontal="60dp"
        android:gravity="center"
        android:text="@string/tutorial_completion_description"
        android:textColor="@color/neutral_0"
        android:textSize="16sp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toLeftOf="@id/gl_left_vertical"
        app:layout_constraintRight_toRightOf="@id/gl_right_vertical"/>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_feedback_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="80dp"
        android:layout_marginHorizontal="60dp"
        app:layout_constraintTop_toBottomOf="@id/tv_description"
        app:layout_constraintLeft_toLeftOf="@id/gl_left_vertical"
        app:layout_constraintRight_toRightOf="@id/gl_right_vertical"
        tool:visibility="gone">

        <TextView
            android:id="@+id/tv_feedback_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:text="@string/tutorial_feedback_title"
            android:textColor="@color/neutral_0"
            android:textSize="16sp"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <View
            android:id="@+id/view_ripple"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="13.3dp"
            android:background="@drawable/bg_circle_faba00"
            android:visibility="invisible"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toRightOf="parent"/>

        <Button
            android:id="@+id/button_thumb_up"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="13.3dp"
            android:background="@drawable/selector_feedback_thumb_up"
            app:layout_constraintHorizontal_chainStyle="packed"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toLeftOf="parent"
            app:layout_constraintRight_toLeftOf="@id/button_thumb_down"
            tool:visibility="visible"/>

        <Button
            android:id="@+id/button_thumb_down"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_marginTop="13.3dp"
            android:layout_marginLeft="10.6dp"
            android:background="@drawable/selector_feedback_thumb_down"
            app:layout_goneMarginLeft="0dp"
            app:layout_constraintTop_toBottomOf="@id/tv_feedback_title"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintLeft_toRightOf="@id/button_thumb_up"
            app:layout_constraintRight_toRightOf="parent"
            tool:visibility="visible"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>