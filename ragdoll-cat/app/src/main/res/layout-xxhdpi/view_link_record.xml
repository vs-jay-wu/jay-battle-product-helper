<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_root"
    android:layout_width="161.33dp"
    android:layout_height="146.66dp"
    android:background="@drawable/bg_neutral0_radius800_line_neutral450_border400"
    android:paddingVertical="5.33dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_top_panel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/tv_seat_number"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:background="@drawable/bg_records_seat_number_enable"
            android:gravity="center"
            android:maxLines="1"
            android:textColor="@color/neutral_0"
            android:textSize="12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="2" />

        <TextView
            android:id="@+id/tv_name"
            android:layout_width="78.66dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="6.66dp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/records_name_enable_text_color"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toEndOf="@+id/tv_seat_number"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Andy Rubin Andy Rubin" />

        <androidx.appcompat.widget.AppCompatCheckBox
            android:id="@+id/cb_select"
            android:layout_width="14.16dp"
            android:layout_height="14.16dp"
            android:background="@null"
            android:button="@drawable/selector_records_check_box"
            android:checked="false"
            android:gravity="center_vertical"
            android:visibility="gone"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_center_panel"
        android:layout_width="129.33dp"
        android:layout_height="66.66dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/cl_link_meta"
            android:layout_width="129.33dp"
            android:layout_height="51.43dp"
            android:layout_marginTop="2.66dp"
            android:background="@drawable/bg_neutral0_radius150_commonstrokecolor_border200"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_link_thumbnail"
                android:layout_width="38.29dp"
                android:layout_height="43.26dp"
                android:layout_marginStart="4.08dp"
                android:scaleType="centerCrop"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:srcCompat="@drawable/ic_link_task_placeholder" />

            <TextView
                android:id="@+id/tv_link_title"
                android:layout_width="76.74dp"
                android:layout_height="18.89dp"
                android:layout_marginStart="6.12dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="2"
                android:textColor="@color/push_and_respond_link_task_title_text_color"
                android:textSize="6.12sp"
                android:textStyle="bold"
                app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                app:layout_constraintTop_toTopOf="@+id/iv_link_thumbnail"
                tools:text="ViewSonic ClassSwift ClassSwift ClassSwift ClassSwift" />

            <TextView
                android:id="@+id/tv_link_description"
                android:layout_width="76.74dp"
                android:layout_height="15.33dp"
                android:layout_marginStart="6.12dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="2"
                android:textColor="@color/push_and_respond_link_task_description_text_color"
                android:textSize="5.1sp"
                app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                app:layout_constraintTop_toBottomOf="@+id/tv_link_title"
                tools:text="ViewSonic ClassSwift ViewSonic ClassSwift ViewSonic ClassSwift" />

            <TextView
                android:id="@+id/tv_link_url"
                android:layout_width="76.74dp"
                android:layout_height="9.04dp"
                android:layout_marginStart="6.12dp"
                android:ellipsize="end"
                android:gravity="center_vertical"
                android:maxLines="1"
                android:textColor="@color/push_and_respond_url_preview_link_text_color"
                android:textSize="6.66sp"
                android:visibility="visible"
                app:layout_constraintStart_toEndOf="@+id/iv_link_thumbnail"
                app:layout_constraintTop_toBottomOf="@+id/tv_link_description"
                tools:text="https://viewsonic.com" />

        </androidx.constraintlayout.widget.ConstraintLayout>

        <TextView
            android:id="@+id/tv_url"
            android:layout_width="124.57dp"
            android:layout_height="10.12dp"
            android:layout_marginTop="5.10dp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:linksClickable="false"
            android:maxLines="1"
            android:textColor="@color/push_and_respond_link_task_url_text_color"
            android:textSize="6.12sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@+id/cl_link_meta"
            tools:text="http://www.google.com" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/cl_bottom_panel"
        android:layout_width="match_parent"
        android:layout_height="32dp"
        android:paddingHorizontal="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <TextView
            android:id="@+id/tv_open_link_status"
            android:layout_width="wrap_content"
            android:layout_height="16.66dp"
            android:ellipsize="end"
            android:gravity="center_vertical"
            android:maxLines="1"
            android:textColor="@color/records_not_submitted_text_color"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Absent" />

        <androidx.appcompat.widget.AppCompatButton
            android:id="@+id/acb_add_point"
            android:layout_width="32dp"
            android:layout_height="20dp"
            android:background="@drawable/bg_records_add_point"
            android:ellipsize="end"
            android:gravity="center"
            android:maxLines="1"
            android:text="@string/records_add_point"
            android:textColor="@color/neutral_0"
            android:textSize="13.33sp"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

    <TextView
        android:id="@+id/tv_add_point_animator"
        android:layout_width="20dp"
        android:layout_height="20dp"
        android:layout_marginBottom="12dp"
        android:background="@color/transparent"
        android:ellipsize="end"
        android:gravity="center"
        android:maxLines="1"
        android:padding="0dp"
        android:text="@string/records_add_point"
        android:textColor="@color/records_add_point_animator_text_color"
        android:textSize="13.33sp"
        android:visibility="gone"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        tools:text="+1" />

    <View
        android:id="@+id/view_mask"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@drawable/bg_white_a50_radius800_line_white_a50_boarder400"
        android:visibility="gone" />

</androidx.constraintlayout.widget.ConstraintLayout>