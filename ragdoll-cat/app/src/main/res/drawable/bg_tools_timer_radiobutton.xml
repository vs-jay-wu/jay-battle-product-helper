<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Disabled -->
    <item android:state_enabled="false">
        <layer-list>
            <item android:width="20dp" android:height="20dp">
                <shape android:shape="oval">
                    <solid android:color="@color/color_EBEBEB" />
                    <stroke android:width="1dp" android:color="@color/neutral_450" />
                </shape>
            </item>
        </layer-list>
    </item>
    <!-- Checked -->
    <item android:state_checked="true">
        <layer-list>
            <!-- 外圓 -->
            <item android:width="20dp" android:height="20dp">
                <shape android:shape="oval">
                    <solid android:color="@android:color/transparent" />
                    <stroke android:width="1dp" android:color="@color/color_0A8CF0" />
                </shape>
            </item>
            <!-- 內圓 -->
            <item android:gravity="center">
                <inset android:inset="5dp">
                    <shape android:shape="oval">
                        <solid android:color="@color/color_0A8CF0" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
    <!-- Unchecked -->
    <item android:state_checked="false">
        <layer-list>
            <item android:width="20dp" android:height="20dp">
                <shape android:shape="oval">
                    <solid android:color="@android:color/transparent" />
                    <stroke android:width="1dp" android:color="@color/neutral_450" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>