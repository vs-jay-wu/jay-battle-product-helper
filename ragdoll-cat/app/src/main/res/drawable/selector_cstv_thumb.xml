<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_checked="true">
        <shape android:shape="oval">
            <solid android:color="@color/brand_blue" />
            <size
                android:width="20dp"
                android:height="20dp" />
            <corners android:radius="10dp" />
        </shape>
    </item>
    <item>
        <shape android:shape="oval">
            <solid android:color="@color/cs_switch_bg_disable" />
            <size
                android:width="20dp"
                android:height="20dp" />
            <corners android:radius="10dp" />
        </shape>
    </item>
</selector>
