<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:paddingHorizontal="9.6dp"
    android:paddingVertical="7.2dp"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:theme="@style/Base.Theme.ClassSwift"
    android:background="@drawable/bg_window_prompt"
    tools:ignore="ContentDescription">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:textColor="@color/white"
        android:textSize="15sp"
        tools:text="@string/instant_push_title"/>

    <TextView
        android:id="@+id/tv_upgrade_button"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="6dp"
        android:paddingHorizontal="1.26dp"
        android:paddingVertical="1dp"
        android:textAllCaps="true"
        android:textColor="@color/white"
        android:textSize="7.53sp"
        android:textStyle="bold"
        android:text="@string/common_soon"
        android:background="@drawable/bg_toolbar_prompt_button"
        android:backgroundTint="@color/color_F4BA00"/>

</LinearLayout>
