<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_neutral0_radius800_line_neutral_500_border200"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <View
        android:id="@+id/view_space"
        android:layout_width="0dp"
        android:layout_height="10.66dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_check"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        app:layout_constraintTop_toBottomOf="@id/view_space"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:srcCompat="@drawable/ic_check_bg_green500_circle"
        tools:visibility="visible" />

    <FrameLayout
        android:id="@+id/fl_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.66dp"
        android:layout_marginStart="10.66dp"
        app:layout_constraintTop_toBottomOf="@id/view_space"
        app:layout_constraintStart_toEndOf="@id/iv_check"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_goneMarginStart="8dp"
        app:layout_goneMarginBottom="10.66dp">

        <TextView
            android:id="@+id/tv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/neutral_900"
            android:textSize="16sp"
            tools:text="@string/text_true"
            tools:visibility="visible" />

        <com.viewsonic.classswift.ui.widget.KatexView
            android:id="@+id/cskv_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/neutral_900"
            android:textSize="16sp"
            tools:visibility="visible" />

    </FrameLayout>

    <FrameLayout
        android:id="@+id/fl_reason"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="5.33dp"
        android:layout_marginBottom="10.66dp"
        android:layout_marginStart="10.66dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toEndOf="@id/iv_check"
        app:layout_constraintTop_toBottomOf="@id/fl_content"
        app:layout_goneMarginStart="8dp"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tv_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/neutral_750"
            android:textSize="16sp"
            tools:text="The option is incorrect, because simony refers to the buying or selling of sacred spiritual things, such as the sacraments or holy offices, and is not specifically related to the sale of indulgences."
            tools:visibility="visible" />

        <com.viewsonic.classswift.ui.widget.KatexView
            android:id="@+id/cskv_reason"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="@color/neutral_750"
            android:textSize="16sp"
            tools:visibility="visible" />

    </FrameLayout>

    <View
        android:id="@+id/view_horizontal_divider"
        android:layout_width="0dp"
        android:layout_height="1dp"
        android:background="@color/neutral_450"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"/>
</merge>