<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:background="@drawable/bg_neutral0_radius800_line_neutral_500_border200"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <TextView
        android:id="@+id/tv_quiz_tag"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27.33dp"
        android:layout_marginEnd="10.66dp"
        android:includeFontPadding="false"
        android:textColor="@color/neutral_750"
        android:textSize="13.33sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toStartOf="@id/view_vertical_divider"
        app:layout_constraintTop_toTopOf="parent"
        tools:text="History" />

    <View
        android:id="@+id/view_vertical_divider"
        android:layout_width="1dp"
        android:layout_height="12dp"
        android:layout_marginEnd="10.66dp"
        android:background="@color/neutral_750"
        app:layout_constraintBottom_toBottomOf="@id/tv_quiz_type"
        app:layout_constraintEnd_toStartOf="@id/tv_quiz_type"
        app:layout_constraintTop_toTopOf="@id/tv_quiz_type" />

    <TextView
        android:id="@+id/tv_quiz_type"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="27.33dp"
        android:layout_marginEnd="20dp"
        android:includeFontPadding="false"
        android:text="@string/quiz_types_short_answer"
        android:textColor="@color/neutral_750"
        android:textSize="13.33sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible" />

    <com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView
        android:id="@+id/fsv_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="12dp"
        app:layout_constraintTop_toBottomOf="@id/tv_quiz_tag"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:paddingBottom="48.66dp">

            <TextView
                android:id="@+id/tv_quiz_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                android:includeFontPadding="false"
                android:textColor="@color/neutral_900"
                android:textSize="18.66sp"
                android:textStyle="bold"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                tools:text="What was the Catholic Church's practice of selling indulgences as a way to raise money and weaken its authority? "
                tools:visibility="visible" />

            <com.viewsonic.classswift.ui.widget.KatexView
                android:id="@+id/cskv_quiz_content"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginHorizontal="26.66dp"
                android:includeFontPadding="false"
                android:textColor="@color/neutral_900"
                android:textSize="18.66sp"
                android:textStyle="bold"
                app:layout_constraintTop_toTopOf="parent"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <androidx.constraintlayout.widget.Barrier
                android:id="@+id/barrier_quiz_content_bottom"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                app:barrierDirection="bottom"
                app:constraint_referenced_ids="tv_quiz_content,cskv_quiz_content" />

            <TextView
                android:id="@+id/tv_reason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="26.66dp"
                android:layout_marginBottom="10.66dp"
                android:layout_marginHorizontal="34.66dp"
                android:textColor="@color/neutral_750"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/barrier_quiz_content_bottom"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="The option is incorrect, because simony refers to the buying or selling of sacred spiritual things, such as the sacraments or holy offices, and is not specifically related to the sale of indulgences."
                tools:visibility="visible" />

            <com.viewsonic.classswift.ui.widget.KatexView
                android:id="@+id/cskv_reason"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_marginTop="26.66dp"
                android:layout_marginBottom="10.66dp"
                android:layout_marginHorizontal="34.66dp"
                android:textColor="@color/neutral_750"
                android:textSize="16sp"
                app:layout_constraintTop_toBottomOf="@id/barrier_quiz_content_bottom"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

        </androidx.constraintlayout.widget.ConstraintLayout>

    </com.viewsonic.classswift.ui.widget.fastscroll.FastScrollView>

</merge>