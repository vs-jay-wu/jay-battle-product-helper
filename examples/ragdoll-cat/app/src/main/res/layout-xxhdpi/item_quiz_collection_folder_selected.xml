<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_root_view"
    android:layout_width="123.33dp"
    android:layout_height="32dp"
    android:layout_marginHorizontal="5.33dp"
    android:background="@drawable/bg_neutral200_no_border_radius400"
    android:paddingHorizontal="8dp"
    android:paddingVertical="6.66dp">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="20dp"
        android:layout_marginEnd="6.66dp"
        android:includeFontPadding="false"
        android:gravity="center_vertical"
        android:ellipsize="end"
        android:maxLines="1"
        android:textColor="@color/color_0A8CF0"
        android:textSize="13.33sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/iv_arrow"
        tools:text="Folder 1tv_titletv_titletv_titletv_titletv_title" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_arrow"
        android:layout_width="16dp"
        android:layout_height="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:srcCompat="@drawable/ic_records_list_arrow"/>

</androidx.constraintlayout.widget.ConstraintLayout>