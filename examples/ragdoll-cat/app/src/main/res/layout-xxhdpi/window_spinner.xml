<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="738dp"
    android:layout_height="597.66dp"
    android:background="@drawable/bg_f5f5f5_radius800_line_neutral450_border400">

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="13.33dp"
        android:layout_marginTop="8dp"
        android:text="@string/toolbar_menu_interaction_spinner"
        android:textColor="@color/spinner_window_title_text_color"
        android:textSize="32sp"
        android:textStyle="bold"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <ImageButton
        android:id="@+id/ib_close"
        android:layout_width="21.33dp"
        android:layout_height="21.33dp"
        android:layout_marginTop="6.55dp"
        android:layout_marginEnd="8.33dp"
        android:background="@drawable/ic_close_64dp"
        android:backgroundTint="@color/bg_close_button"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <WebView
        android:id="@+id/wv_web_view"
        android:layout_width="685dp"
        android:layout_height="525dp"
        android:layout_marginHorizontal="26.33dp"
        android:layout_marginBottom="16dp"
        android:background="@color/transparent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/tv_title" />

    <com.viewsonic.classswift.ui.widget.NetworkDisconnectView
        android:id="@+id/ndv_network_disconnect_mask"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:visibility="gone"
        app:cardRadius="@dimen/radius_800"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>