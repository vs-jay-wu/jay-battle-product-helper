<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_mask_radius800"
    tools:parentTag="androidx.constraintlayout.widget.ConstraintLayout">

    <androidx.cardview.widget.CardView
        android:layout_width="382dp"
        android:layout_height="wrap_content"
        android:clipChildren="true"
        android:clipToPadding="true"
        app:cardBackgroundColor="@color/cs_system_dialog_normal_background"
        app:cardCornerRadius="5.33dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_close"
                android:layout_width="21.3dp"
                android:layout_height="21.3dp"
                android:layout_marginTop="10.6dp"
                android:layout_marginEnd="10.6dp"
                app:layout_constraintRight_toRightOf="parent"
                app:layout_constraintTop_toTopOf="parent"
                app:tint="@color/bg_close_button"
                app:srcCompat="@drawable/ic_close_64dp" />

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:includeFontPadding="false"
                android:layout_marginHorizontal="26.66dp"
                android:text="@string/quiz_collection_folder_create_dialog_title"
                android:textSize="24sp"
                android:textStyle="bold"
                android:textColor="@color/color_2E3133"
                app:layout_constraintTop_toBottomOf="@id/iv_close"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:visibility="visible"/>

            <EditText
                android:id="@+id/et_folder_name"
                android:layout_width="0dp"
                android:layout_height="34.6dp"
                android:layout_marginTop="16dp"
                android:layout_marginHorizontal="26.66dp"
                android:paddingStart="12dp"
                android:paddingEnd="48dp"
                android:background="@drawable/selector_create_folder_edittext"
                android:maxLength="30"
                android:maxLines="1"
                android:inputType="text"
                android:text="@string/untitled_folder"
                android:textSize="16sp"
                android:textColor="@color/color_2E3133"
                app:layout_constraintTop_toBottomOf="@id/tv_title"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"/>

            <TextView
                android:id="@+id/tv_folder_name_count"
                android:layout_width="0dp"
                android:layout_height="36dp"
                android:layout_marginEnd="10.66dp"
                android:gravity="end|center_vertical"
                android:text="0/50"
                android:textColor="@color/window_my_class_textview_sub_text"
                android:textSize="16sp"
                app:layout_constraintTop_toTopOf="@id/et_folder_name"
                app:layout_constraintBottom_toBottomOf="@id/et_folder_name"
                app:layout_constraintEnd_toEndOf="@id/et_folder_name"
                app:layout_constraintHorizontal_weight="1" />

            <TextView
                android:id="@+id/tv_error_msg"
                android:layout_width="0dp"
                android:layout_height="81.33dp"
                android:includeFontPadding="false"
                android:layout_marginTop="5.33dp"
                android:layout_marginHorizontal="26.66dp"
                android:textSize="13.33sp"
                android:textColor="@color/color_F02B2B"
                app:layout_constraintTop_toBottomOf="@id/et_folder_name"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                tools:text="The folder name cannot be the same as the Home folder.\nPlease enter a different name."
                tools:visibility="visible"/>

            <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
                android:id="@+id/cslb_cancel"
                android:layout_width="153.33dp"
                android:layout_height="37.33dp"
                android:layout_marginTop="5.33dp"
                android:layout_marginBottom="16dp"
                android:layout_marginEnd="10.66dp"
                android:clickable="true"
                app:layout_constraintTop_toBottomOf="@id/tv_error_msg"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toStartOf="@id/cslb_create"
                app:layout_constraintStart_toStartOf="parent"
                app:layout_constraintHorizontal_chainStyle="packed"
                app:lbBackgroundColor="@color/white"
                app:lbBorderColor="@color/color_0A8CF0"
                app:lbText="@string/common_cancel"
                app:lbTextColor="@color/color_0A8CF0"
                app:lbTextSize="14sp" />

            <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
                android:id="@+id/cslb_create"
                android:layout_width="153.33dp"
                android:layout_height="37.33dp"
                android:layout_marginTop="5.33dp"
                android:layout_marginBottom="16dp"
                android:clickable="true"
                app:layout_constraintTop_toBottomOf="@id/tv_error_msg"
                app:layout_constraintBottom_toBottomOf="parent"
                app:layout_constraintEnd_toEndOf="parent"
                app:layout_constraintStart_toEndOf="@id/cslb_cancel"
                app:lbBackgroundColor="@color/color_0A8CF0"
                app:lbDisableBackgroundColor="@color/neutral_500"
                app:lbLoadingBackground="@color/color_0A8CF0"
                app:lbProgressIndicatorColor="@color/white"
                app:lbText="@string/common_create"
                app:lbTextColor="@color/white"
                app:lbTextSize="14sp" />

        </androidx.constraintlayout.widget.ConstraintLayout>

    </androidx.cardview.widget.CardView>

</merge>