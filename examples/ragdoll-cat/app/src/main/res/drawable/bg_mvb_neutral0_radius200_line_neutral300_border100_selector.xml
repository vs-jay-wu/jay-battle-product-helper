<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">

    <item android:state_selected="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/neutral_0" />
                    <stroke android:width="@dimen/mvb_border_200" android:color="@color/violet_500" />
                    <corners android:radius="@dimen/mvb_radius_200" />
                </shape>
            </item>
            <item android:bottom="@dimen/mvb_spacing_50" android:left="@dimen/mvb_spacing_50" android:right="@dimen/mvb_spacing_50" android:top="@dimen/mvb_spacing_50">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neutral_0" />
                    <corners android:radius="@dimen/mvb_radius_200" />
                </shape>
            </item>
            <item android:bottom="@dimen/mvb_spacing_100" android:left="@dimen/mvb_spacing_100" android:right="@dimen/mvb_spacing_100" android:top="@dimen/mvb_spacing_100">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neutral_0" />
                    <stroke android:width="@dimen/mvb_border_100" android:color="@color/violet_500" />
                    <corners android:radius="@dimen/mvb_radius_200" />
                </shape>
            </item>
        </layer-list>
    </item>

    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/transparent" />
                </shape>
            </item>
            <item android:bottom="@dimen/mvb_spacing_100" android:left="@dimen/mvb_spacing_100" android:right="@dimen/mvb_spacing_100" android:top="@dimen/mvb_spacing_100">
                <shape android:shape="rectangle">
                    <solid android:color="@color/neutral_0" />
                    <stroke android:width="@dimen/mvb_border_100" android:color="@color/neutral_300" />
                    <corners android:radius="@dimen/mvb_radius_200" />
                </shape>
            </item>
        </layer-list>
    </item>

</selector>
