<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <!-- 外框 -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/window_crop_image_button_disable_bg" />
                    <stroke android:width="1.3dp" android:color="@color/window_crop_image_view_stroke" />
                    <corners android:radius="5.3dp" />
                </shape>
            </item>
            <!-- 內框（使用 inset 讓它縮小） -->
            <item>
                <inset android:insetLeft="12dp" android:insetTop="9dp" android:insetRight="12dp" android:insetBottom="9dp">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/window_crop_image_button_disable_bg" />
                        <stroke android:width="1.3dp" android:color="@color/window_crop_image_view_stroke" />
                        <corners android:radius="5.3dp" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <!-- 外框 -->
            <item>
                <shape android:shape="rectangle">
                    <solid android:color="@color/window_crop_image_button_bg" />
                    <stroke android:width="1.3dp" android:color="@color/window_crop_image_view_stroke" />
                    <corners android:radius="5.3dp" />
                </shape>
            </item>

            <!-- 內框（使用 inset 讓它縮小） -->
            <item>
                <inset android:insetLeft="12dp" android:insetTop="9dp" android:insetRight="12dp" android:insetBottom="9dp">
                    <shape android:shape="rectangle">
                        <solid android:color="@color/window_crop_image_button_bg" />
                        <stroke android:width="1.3dp" android:color="@color/window_crop_image_view_stroke" />
                        <corners android:radius="5.3dp" />
                    </shape>
                </inset>
            </item>
        </layer-list>
    </item>
</selector>
