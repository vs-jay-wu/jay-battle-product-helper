<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_tooltip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <View
        android:id="@+id/view_background"
        android:layout_width="226dp"
        android:layout_height="0dp"
        android:layout_marginTop="-1dp"
        android:layout_marginStart="-1.3dp"
        android:background="@drawable/bg_neutral100_radius800"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/space_bottom"
        app:layout_constraintLeft_toLeftOf="parent"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="10.66dp"
        android:layout_marginTop="10.66dp"
        android:gravity="center"
        android:text="@string/tutorial_learn_mode_qrcode_title"
        android:textColor="@color/neutral_950"
        android:textSize="14.7sp"
        app:layout_constraintTop_toTopOf="@id/view_background"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"/>

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_qr_code"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_marginTop="3dp"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"/>

    <TextView
        android:id="@+id/button_close"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="10.66dp"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:background="@drawable/bg_neutral900_radius200"
        android:gravity="center"
        android:text="@string/common_close"
        android:textColor="@color/neutral_150"
        android:textSize="10.66sp"
        app:layout_constraintTop_toBottomOf="@id/iv_qr_code"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"/>

    <Space
        android:id="@+id/space_bottom"
        android:layout_width="0dp"
        android:layout_height="10.66dp"
        app:layout_constraintTop_toBottomOf="@id/button_close"
        app:layout_constraintBottom_toTopOf="@id/iv_bottom_arrow"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background" />

    <androidx.appcompat.widget.AppCompatImageView
        android:id="@+id/iv_bottom_arrow"
        android:layout_width="19.33dp"
        android:layout_height="10.66dp"
        android:layout_marginTop="-1dp"
        android:src="@drawable/ic_bottom_arrow_neutral_950"
        app:tint="@color/neutral_100"
        app:layout_constraintTop_toBottomOf="@id/space_bottom"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

</androidx.constraintlayout.widget.ConstraintLayout>
