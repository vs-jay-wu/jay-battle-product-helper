<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:clipChildren="false"
    android:clipToPadding="false"
    android:padding="@dimen/mvb_spacing_300"
    tools:ignore="ContentDescription">

    <FrameLayout
        android:id="@+id/fl_shell_root"
        android:layout_width="@dimen/quiz_mvb_poll_start_window_width"
        android:layout_height="@dimen/quiz_mvb_poll_start_window_height"
        android:background="@drawable/bg_cs_window_no_border_radius800"
        android:clipToOutline="true"
        android:elevation="@dimen/mvb_spacing_200"
        android:outlineProvider="background">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:orientation="vertical">

            <!-- Header (mirrors MvbShortAnswerStartWindow's header) -->
            <FrameLayout
                android:id="@+id/fl_header"
                android:layout_width="match_parent"
                android:layout_height="@dimen/quiz_mvb_header_height"
                android:background="@drawable/bg_neutral0_radius800_top"
                android:paddingHorizontal="@dimen/mvb_spacing_400">

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="start|center_vertical"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:layout_width="@dimen/mvb_spacing_800"
                        android:layout_height="@dimen/mvb_spacing_800"
                        android:layout_marginEnd="@dimen/mvb_spacing_200"
                        android:src="@drawable/ic_mvb_quizzing_header"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tv_header_title"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif"
                        android:text="@string/mvb_sketch_response_result_window_title"
                        android:textColor="@color/neutral_900"
                        android:textSize="@dimen/quiz_mvb_text_md"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:layout_width="wrap_content"
                    android:layout_height="match_parent"
                    android:layout_gravity="end|center_vertical"
                    android:gravity="center_vertical"
                    android:orientation="horizontal">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_minimize_window"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_marginEnd="@dimen/mvb_spacing_400"
                        android:src="@drawable/ic_minus_32dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        android:visibility="gone"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_toolbar_bring_to_front"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_marginEnd="@dimen/mvb_spacing_300"
                        android:src="@drawable/ic_toolbar_bring_to_front_64dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        android:visibility="gone"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_close"
                        android:layout_width="@dimen/quiz_mvb_icon_size_sm"
                        android:layout_height="@dimen/quiz_mvb_icon_size_sm"
                        android:src="@drawable/ic_close_64dp"
                        android:background="@drawable/ripple_neutral300_oval"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />
                </LinearLayout>
            </FrameLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_E6E6E6" />

            <!-- Body: FrameLayout 包雙 panel，applyPanelVisibility 依 SketchState 互斥顯示 -->
            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1">

                <!-- ANSWERING panel（Jacky 派題 / 監控視圖，預設顯示） -->
                <include
                    android:id="@+id/panel_quizzing"
                    layout="@layout/panel_mvb_quizzing"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent" />

                <!-- RESULT panel（結果頁，預設隱藏；collectAllAndMark 後切換為 VISIBLE） -->
                <include
                    android:id="@+id/panel_result"
                    layout="@layout/panel_mvb_sketch_response_result"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:visibility="gone" />
            </FrameLayout>
        </LinearLayout>

        <!--
          ~ Sketch review overlay：點學生 card 後 visible，覆蓋整個 fl_shell_root。
          ~ 僅 RESULT 狀態下使用；位於 close_confirm 之下。
          -->
        <!-- Sketch review overlay：dim 背景讓內層白色 dialog box 有懸浮效果 -->
        <com.viewsonic.classswift.ui.widget.quiz.result.SketchReviewWidget
            android:id="@+id/srw_sketch_review"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@color/black_a40"
            android:visibility="gone"
            tools:visibility="gone" />

        <!--
          ~ Load-failed toast：fetchAndEmit / getStudentTasks 失敗時顯示（RESULT 狀態）。
          ~ marginBottom = pagination divider (1dp) + pagination bar (42.67dp) + spacing (10.67dp) ≈ 54dp
          ~ 效果：浮在 pagination 分隔線上方，對齊其他題型 bottom toast 做法。
          -->
        <com.viewsonic.classswift.ui.widget.MvbToast
            android:id="@+id/mt_load_failed_toast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="54dp"
            android:visibility="gone"
            app:mtHasActionButton="false"
            app:mtHasCloseButton="false"
            app:mtToastLevel="level_danger" />

        <com.viewsonic.classswift.ui.widget.MvbToast
            android:id="@+id/mt_refresh_error_toast"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|center_horizontal"
            android:layout_marginBottom="@dimen/mvb_spacing_400"
            android:visibility="gone"
            app:mtHasActionButton="false"
            app:mtHasCloseButton="false"
            app:mtToastLevel="level_danger" />

        <com.viewsonic.classswift.ui.widget.dialog.MvbSystemDialogView
            android:id="@+id/msdv_close_confirm"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />
    </FrameLayout>
</FrameLayout>
