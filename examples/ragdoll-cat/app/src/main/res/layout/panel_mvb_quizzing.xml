<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/fl_quizzing_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/neutral_0">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal">

    <!-- ============================================================ -->
    <!-- Left: Question Section (Figma 500 scaled width)                   -->
    <!-- ============================================================ -->
    <LinearLayout
        android:id="@+id/ll_question_section"
        android:layout_width="@dimen/quiz_mvb_panel_left_width"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:paddingHorizontal="16dp"
        android:paddingVertical="16dp">

        <!-- Row 1: Quiz type + stopwatch -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_quiz_type_icon"
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:layout_marginEnd="@dimen/mvb_spacing_100"
                android:src="@drawable/ic_check_cross_circle"
                app:tint="@color/neutral_900"
                tools:ignore="UseAppTint" />

            <TextView
                android:id="@+id/tv_quiz_type_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:fontFamily="sans-serif"
                android:textColor="@color/neutral_900"
                android:textSize="@dimen/quiz_mvb_text_md"
                android:textStyle="bold"
                tools:text="True or false" />

            <TextView
                android:id="@+id/tv_quiz_type_subtitle"
                android:layout_width="wrap_content"
                android:layout_height="16dp"
                android:layout_marginStart="@dimen/mvb_spacing_200"
                android:background="@drawable/bg_mvb_quizzing_type_badge"
                android:fontFamily="sans-serif-medium"
                android:gravity="center"
                android:paddingHorizontal="@dimen/mvb_spacing_200"
                android:textColor="@color/neutral_900"
                android:textSize="@dimen/quiz_mvb_text_xs"
                android:visibility="gone"
                tools:text="Multi-select"
                tools:visibility="visible" />

            <Space
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:layout_weight="1" />

            <LinearLayout
                android:id="@+id/ll_stopwatch_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/mvb_spacing_100"
                    android:src="@drawable/ic_mvb_quizzing_stopwatch"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/tv_stopwatch"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/quiz_mvb_quizzing_stopwatch_default"
                    android:textColor="@color/neutral_500"
                    android:textSize="12sp" />
            </LinearLayout>
        </LinearLayout>

        <!-- Row 2: Screenshot Preview (Figma 452×254 → 301×169dp, radius 12→8dp, stroke E5E5E5) -->
        <FrameLayout
            android:layout_width="match_parent"
            android:layout_height="169dp"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:background="@drawable/bg_neutral0_radius600_line_neutral300_border200"
            android:clipToOutline="true">

            <com.viewsonic.classswift.ui.widget.quiz.MvbImageUploadView
                android:id="@+id/cs_screenshot_image"
                android:layout_width="match_parent"
                android:layout_height="match_parent" />
        </FrameLayout>

        <!-- Row 3a: Quizzing options area (header + chips) -->
        <LinearLayout
            android:id="@+id/ll_quizzing_options_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Options section label (icon + "Options") -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/mvb_spacing_100"
                    android:src="@drawable/ic_mvb_quizzing_options"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/tv_options_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/quiz_mvb_quizzing_options_title"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_md"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- Option chips (T/F, 1-N, or A-F). Populated in code. -->
            <LinearLayout
                android:id="@+id/ll_options_row"
                android:layout_width="match_parent"
                android:layout_height="@dimen/quiz_mvb_option_row_height"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:orientation="horizontal" />
        </LinearLayout>

        <!-- Row 3b: Disclose selector card (disclose mode) -->
        <LinearLayout
            android:id="@+id/ll_disclose_selector_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:background="@drawable/bg_neutral0_radius600_line_neutral300_border200"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/mvb_spacing_250"
            android:paddingTop="@dimen/mvb_spacing_400"
            android:paddingBottom="16dp"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="@dimen/mvb_spacing_400"
                    android:layout_height="@dimen/mvb_spacing_400"
                    android:layout_marginEnd="@dimen/mvb_spacing_100"
                    android:src="@drawable/ic_check_white"
                    app:tint="@color/neutral_900"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/tv_disclose_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/quiz_disclose_select_the_correct_answer"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_md"
                    android:textStyle="bold" />
            </LinearLayout>

            <com.viewsonic.classswift.ui.widget.quiz.disclose.CSDiscloseAnswerOptionGroup
                android:id="@+id/csw_disclose_option_group"
                android:layout_width="match_parent"
                android:layout_height="@dimen/quiz_mvb_option_row_height"
                android:layout_marginTop="@dimen/mvb_spacing_400" />
        </LinearLayout>

        <!-- Row 3c: Result options area (result mode; 3 bar items) -->
        <LinearLayout
            android:id="@+id/ll_result_options_area"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="gone"
            tools:visibility="visible">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/mvb_spacing_100"
                    android:src="@drawable/ic_mvb_quizzing_options"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/quiz_mvb_quizzing_options_title"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_md"
                    android:textStyle="bold" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/mvb_spacing_200"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/quiz_mvb_result_click_to_highlight"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_xs" />
            </LinearLayout>

            <ScrollView
                android:layout_width="match_parent"
                android:layout_height="wrap_content">

                <LinearLayout
                    android:id="@+id/ll_result_bars_container"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/mvb_spacing_200"
                    android:orientation="vertical" />
            </ScrollView>
        </LinearLayout>

        <!-- Spacer pushes bottom button to bottom -->
        <View
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1" />

        <!-- End and Review Button (quizzing mode) -->
        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/button_end_and_review"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mvb_spacing_1400"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:clickable="true"
            app:lbBackgroundColor="@color/neutral_0"
            app:lbBorderColor="@color/red_500"
            app:lbBorderWidth="@dimen/mvb_border_100"
            app:lbButtonState="enable"
            app:lbClickedBackgroundColor="@color/red_500"
            app:lbClickedBorderColor="@color/red_500"
            app:lbClickedTextColor="@color/neutral_0"
            app:lbRadius="@dimen/mvb_radius_200"
            app:lbFontFamily="sans-serif-medium"
            app:lbText="@string/quiz_mvb_quizzing_end_and_review"
            app:lbTextColor="@color/red_500"
            app:lbTextSize="@dimen/quiz_mvb_text_lg" />

        <!-- Publish / Show question(s) result button (disclose mode) -->
        <com.viewsonic.classswift.ui.widget.ClassSwiftLoadingButton
            android:id="@+id/cslb_disclose_publish"
            android:layout_width="match_parent"
            android:layout_height="@dimen/mvb_spacing_1400"
            android:layout_marginTop="@dimen/mvb_spacing_400"
            android:visibility="gone"
            app:lbBackgroundColor="@color/color_4848F0"
            app:lbBorderColor="@color/color_4848F0"
            app:lbButtonState="disable"
            app:lbClickedBackgroundColor="@color/violet_700"
            app:lbClickedBorderColor="@color/violet_700"
            app:lbClickedTextColor="@color/neutral_0"
            app:lbDisableBackgroundColor="@color/neutral_200"
            app:lbDisableBorderColor="@color/neutral_200"
            app:lbDisableTextColor="@color/neutral_500"
            app:lbFontFamily="sans-serif-medium"
            app:lbRadius="@dimen/radius_400"
            app:lbText="@string/quiz_disclose_show_question_result"
            app:lbTextColor="@color/neutral_0"
            app:lbTextSize="@dimen/quiz_mvb_text_lg"
            tools:visibility="visible" />
    </LinearLayout>

    <!-- ============================================================ -->
    <!-- Right: Student Section (Figma 780 → 520dp, weight 1)          -->
    <!-- ============================================================ -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="match_parent"
        android:layout_weight="1"
        android:orientation="vertical"
        android:paddingStart="0dp"
        android:paddingEnd="16dp"
        android:paddingVertical="16dp">

        <!-- F6F6F6 rounded container -->
        <LinearLayout
            android:id="@+id/ll_student_section"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/bg_neutral100_radius800"
            android:orientation="vertical"
            android:paddingHorizontal="@dimen/mvb_spacing_400"
            android:paddingTop="@dimen/mvb_spacing_400"
            android:paddingBottom="@dimen/mvb_spacing_400">

            <!-- Top row: Responses icon+label + Refresh button | 21/30 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <androidx.appcompat.widget.AppCompatImageView
                    android:layout_width="16dp"
                    android:layout_height="16dp"
                    android:layout_marginEnd="@dimen/mvb_spacing_100"
                    android:src="@drawable/ic_mvb_quizzing_responses"
                    tools:ignore="UseAppTint" />

                <TextView
                    android:id="@+id/tv_responses_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:text="@string/quiz_mvb_quizzing_responses_title"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_md"
                    android:textStyle="bold" />

                <LinearLayout
                    android:id="@+id/ll_refresh_button"
                    android:layout_width="wrap_content"
                    android:layout_height="@dimen/mvb_spacing_800"
                    android:layout_marginStart="@dimen/mvb_spacing_400"
                    android:background="@drawable/selector_bg_mvb_refresh_button"
                    android:clickable="true"
                    android:focusable="true"
                    android:gravity="center"
                    android:orientation="horizontal"
                    android:paddingHorizontal="8dp">

                    <androidx.appcompat.widget.AppCompatImageView
                        android:id="@+id/iv_refresh_icon"
                        android:layout_width="@dimen/mvb_spacing_400"
                        android:layout_height="@dimen/mvb_spacing_400"
                        android:layout_marginEnd="@dimen/mvb_spacing_100"
                        android:src="@drawable/ic_arrow_clockwise_16"
                        app:tint="@color/neutral_900"
                        tools:ignore="UseAppTint" />

                    <TextView
                        android:id="@+id/tv_refresh_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/quiz_mvb_quizzing_refresh"
                        android:textColor="@color/neutral_900"
                        android:textSize="@dimen/quiz_mvb_text_sm" />

                    <com.airbnb.lottie.LottieAnimationView
                        android:id="@+id/lav_refresh_loading"
                        android:layout_width="@dimen/mvb_spacing_500"
                        android:layout_height="@dimen/mvb_spacing_500"
                        android:visibility="gone"
                        app:lottie_autoPlay="false"
                        app:lottie_fileName="ani_loading.json"
                        app:lottie_loop="true" />
                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <TextView
                    android:id="@+id/tv_response_count"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_md"
                    tools:text="21 / 30" />
            </LinearLayout>

            <androidx.appcompat.widget.AppCompatImageView
                android:id="@+id/iv_refresh"
                android:layout_width="0dp"
                android:layout_height="0dp"
                android:visibility="gone" />

            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_student_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:layout_weight="1"
                android:clipToPadding="false" />

            <!-- Result mode tab bar (Overview / Student responses) -->
            <LinearLayout
                android:id="@+id/ll_result_tabs"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mvb_spacing_200"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:id="@+id/ll_result_tab_overview"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/mvb_spacing_400"
                    android:paddingTop="@dimen/mvb_spacing_200">

                    <TextView
                        android:id="@+id/tv_result_tab_overview"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/quiz_mvb_result_tab_overview"
                        android:textColor="@color/color_4848F0"
                        android:textSize="@dimen/quiz_mvb_text_sm" />

                    <View
                        android:id="@+id/v_result_tab_indicator_overview"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/quiz_mvb_tab_indicator_height"
                        android:layout_marginTop="@dimen/mvb_spacing_200"
                        android:background="@color/color_4848F0" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/ll_result_tab_student"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/mvb_spacing_400"
                    android:clickable="true"
                    android:focusable="true"
                    android:orientation="vertical"
                    android:paddingHorizontal="@dimen/mvb_spacing_400"
                    android:paddingTop="@dimen/mvb_spacing_200">

                    <TextView
                        android:id="@+id/tv_result_tab_student"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:fontFamily="sans-serif-medium"
                        android:text="@string/quiz_mvb_result_tab_student_responses"
                        android:textColor="@color/neutral_900"
                        android:textSize="@dimen/quiz_mvb_text_sm" />

                    <View
                        android:id="@+id/v_result_tab_indicator_student"
                        android:layout_width="match_parent"
                        android:layout_height="@dimen/quiz_mvb_tab_indicator_height"
                        android:layout_marginTop="@dimen/mvb_spacing_200"
                        android:background="@color/color_4848F0"
                        android:visibility="invisible" />
                </LinearLayout>
            </LinearLayout>

            <!-- Result Overview content (result mode, Overview tab) -->
            <ScrollView
                android:id="@+id/sv_result_overview_content"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:layout_weight="1"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">


                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:background="@drawable/bg_neutral100_radius800_line_neutral300_border400"
                        android:orientation="vertical"
                        android:paddingHorizontal="16dp"
                        android:paddingVertical="@dimen/mvb_spacing_400">

                        <TextView
                            android:id="@+id/tv_result_correct_answer_label"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:fontFamily="sans-serif"
                            android:text="@string/quiz_mvb_result_correct_answer"
                            android:textColor="@color/neutral_900"
                            android:textSize="12sp"
                            android:textStyle="bold" />

                        <LinearLayout
                            android:id="@+id/ll_result_correct_badges"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mvb_spacing_200"
                            android:orientation="horizontal" />

                        <View
                            android:id="@+id/view_result_correct_answer_divider"
                            android:layout_width="match_parent"
                            android:layout_height="@dimen/quiz_mvb_divider_thickness"
                            android:layout_marginTop="@dimen/mvb_spacing_400"
                            android:background="@color/neutral_300" />

                        <!-- 3 analytic chips row -->
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="@dimen/mvb_spacing_200"
                            android:orientation="horizontal">

                            <com.viewsonic.classswift.ui.widget.quiz.result.CSResultAnalyticChip
                                android:id="@+id/csrac_correct"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <View
                                android:id="@+id/v_result_correct_incorrect_divider"
                                android:layout_width="@dimen/quiz_mvb_divider_thickness"
                                android:layout_height="45dp"
                                android:layout_gravity="center_vertical"
                                android:background="@color/neutral_300" />

                            <com.viewsonic.classswift.ui.widget.quiz.result.CSResultAnalyticChip
                                android:id="@+id/csrac_incorrect"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />

                            <View
                                android:layout_width="@dimen/quiz_mvb_divider_thickness"
                                android:layout_height="45dp"
                                android:layout_gravity="center_vertical"
                                android:background="@color/neutral_300" />

                            <com.viewsonic.classswift.ui.widget.quiz.result.CSResultAnalyticChip
                                android:id="@+id/csrac_no_answer"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_weight="1" />
                        </LinearLayout>
                    </LinearLayout>

                    <com.viewsonic.classswift.ui.widget.quiz.result.CSAnswerPieChart
                        android:id="@+id/csapc_result_pie_chart"
                        android:layout_width="160dp"
                        android:layout_height="160dp"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_gravity="center_horizontal"
                        android:layout_marginTop="16dp"
                        android:layout_marginBottom="@dimen/mvb_spacing_400"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/tv_result_legend_correct"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:drawableStart="@drawable/shape_result_legend_dot_correct"
                            android:drawablePadding="@dimen/mvb_spacing_200"
                            android:fontFamily="sans-serif"
                            android:gravity="center_vertical"
                            android:textColor="@color/neutral_900"
                            android:textSize="@dimen/quiz_mvb_text_sm"
                            tools:text="Correct rate 33%" />

                        <TextView
                            android:id="@+id/tv_result_legend_incorrect"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/mvb_spacing_400"
                            android:drawableStart="@drawable/shape_result_legend_dot_incorrect"
                            android:drawablePadding="@dimen/mvb_spacing_200"
                            android:fontFamily="sans-serif"
                            android:gravity="center_vertical"
                            android:textColor="@color/neutral_900"
                            android:textSize="@dimen/quiz_mvb_text_sm"
                            tools:text="Incorrect rate 33%" />

                        <TextView
                            android:id="@+id/tv_result_legend_no_answer"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="@dimen/mvb_spacing_400"
                            android:drawableStart="@drawable/shape_result_legend_dot_no_answer"
                            android:drawablePadding="@dimen/mvb_spacing_200"
                            android:fontFamily="sans-serif"
                            android:gravity="center_vertical"
                            android:textColor="@color/neutral_900"
                            android:textSize="@dimen/quiz_mvb_text_sm"
                            tools:text="No answer 33%" />
                    </LinearLayout>
                </LinearLayout>
            </ScrollView>

            <!-- Show students' name toggle (result mode, Student responses tab only) -->
            <LinearLayout
                android:id="@+id/ll_show_students_name"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:gravity="center_vertical"
                android:orientation="horizontal"
                android:visibility="gone"
                tools:visibility="visible">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-medium"
                    android:text="@string/quiz_mvb_show_students_name"
                    android:textColor="@color/neutral_900"
                    android:textSize="@dimen/quiz_mvb_text_sm" />

                <androidx.appcompat.widget.SwitchCompat
                    android:id="@+id/sw_show_students_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginStart="@dimen/mvb_spacing_200"
                    android:background="@null"
                    android:checked="true"
                    android:switchMinWidth="@dimen/mvb_switch_track_width"
                    android:thumb="@drawable/selector_mvb_audio_switch_thumb"
                    app:track="@drawable/selector_mvb_audio_switch_track" />
            </LinearLayout>

            <!-- Result Student list (result mode, Student responses tab) -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rv_result_student_list"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_marginTop="@dimen/mvb_spacing_400"
                android:layout_weight="1"
                android:clipToPadding="false"
                android:visibility="gone" />
        </LinearLayout>
    </LinearLayout>
    </LinearLayout>

    <com.viewsonic.classswift.ui.widget.CSToast
        android:id="@+id/cst_toast"
        android:layout_width="wrap_content"
        android:layout_height="32dp"
        android:layout_gravity="top|center_horizontal"
        android:layout_marginTop="8dp"
        android:visibility="gone"
        app:successStatus="false"
        tools:visibility="visible" />

</FrameLayout>
