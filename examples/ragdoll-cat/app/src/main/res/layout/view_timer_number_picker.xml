<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:padding="2dp"
    xmlns:app="http://schemas.android.com/apk/res-auto">
    
    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_number_up"
        android:layout_width="39dp"
        android:layout_height="24dp"
        android:background="@drawable/ic_timer_up"
        android:layout_marginBottom="2dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/tv_time_value"
        />

    <androidx.appcompat.widget.AppCompatTextView
        android:id="@+id/tv_time_value"
        android:layout_width="39dp"
        android:layout_height="66.33dp"
        android:text="0"
        android:textColor="@color/neutral_900"
        android:textSize="40sp"
        android:gravity="center"
        android:background="@drawable/bg_timer_number_picker_value"
        android:layout_marginBottom="2dp"
        app:layout_constraintTop_toBottomOf="@id/button_number_up"
        app:layout_constraintBottom_toTopOf="@id/button_number_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        />



    <androidx.appcompat.widget.AppCompatButton
        android:id="@+id/button_number_down"
        android:layout_width="39dp"
        android:layout_height="24dp"
        android:background="@drawable/ic_timer_down"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tv_time_value"
        app:layout_constraintBottom_toBottomOf="parent"
        />



</androidx.constraintlayout.widget.ConstraintLayout>