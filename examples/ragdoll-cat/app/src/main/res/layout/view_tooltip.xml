<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/cl_tooltip"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <ImageView
        android:id="@+id/iv_top_arrow"
        android:layout_width="19.33dp"
        android:layout_height="10.65dp"
        android:src="@drawable/ic_top_arrow_neutral_950"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/iv_bottom_arrow"
        android:layout_width="19.33dp"
        android:layout_height="10.66dp"
        android:src="@drawable/ic_bottom_arrow_neutral_950"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toLeftOf="parent"
        app:layout_constraintRight_toRightOf="parent"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/iv_left_arrow"
        android:layout_width="10dp"
        android:layout_height="18dp"
        android:src="@drawable/ic_left_arrow_neutral_950"
        app:layout_constraintTop_toTopOf="@id/view_background"
        app:layout_constraintBottom_toBottomOf="@id/view_background"
        app:layout_constraintLeft_toLeftOf="parent"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <ImageView
        android:id="@+id/iv_right_arrow"
        android:layout_width="10.66dp"
        android:layout_height="19.33dp"
        android:src="@drawable/ic_right_arrow_neutral_950"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintLeft_toRightOf="@id/view_background"
        app:layout_constraintTop_toTopOf="parent"
        tools:visibility="visible"
        tools:ignore="ContentDescription" />

    <View
        android:id="@+id/view_background"
        android:layout_width="226dp"
        android:layout_height="0dp"
        android:layout_marginTop="-1dp"
        android:layout_marginStart="-1.3dp"
        android:background="@drawable/bg_tooltips"
        app:layout_constraintTop_toBottomOf="@id/iv_top_arrow"
        app:layout_constraintBottom_toBottomOf="@id/space_bottom"
        app:layout_constraintLeft_toRightOf="@id/iv_left_arrow"/>

    <TextView
        android:id="@+id/tv_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="26.66dp"
        android:layout_marginTop="10.66dp"
        android:gravity="center"
        android:textColor="@color/neutral_0"
        android:textSize="14.7sp"
        app:layout_constraintTop_toBottomOf="@id/iv_top_arrow"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"
        tools:text="Your Class Roster is Ready" />

    <com.airbnb.lottie.LottieAnimationView
        android:id="@+id/lav_image"
        android:layout_width="120dp"
        android:layout_height="120dp"
        app:lottie_autoPlay="true"
        app:lottie_loop="true"
        app:layout_constraintTop_toBottomOf="@id/tv_title"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"/>

    <TextView
        android:id="@+id/tv_description"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="26.66dp"
        android:gravity="center"
        android:textColor="@color/neutral_400"
        android:textSize="12sp"
        app:layout_constraintTop_toBottomOf="@id/lav_image"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background"
        tools:text="You’re all set! Choose a class from the list to get started." />


    <TextView
        android:id="@+id/tv_negative"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="26.66dp"
        android:text="@string/tutorial_dialog_action_skip_all"
        android:textColor="@color/neutral_150"
        android:textSize="10.66sp"
        app:layout_constraintHorizontal_chainStyle="spread_inside"
        app:layout_constraintTop_toTopOf="@id/tv_positive"
        app:layout_constraintBottom_toBottomOf="@id/tv_positive"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toLeftOf="@id/tv_positive"
        tools:visibility="visible"
        tools:ignore="SmallSp" />

    <TextView
        android:id="@+id/tv_positive"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginVertical="10.66dp"
        android:layout_marginEnd="26.66dp"
        android:background="@drawable/bg_tooltips_got_it_button"
        android:paddingHorizontal="8dp"
        android:paddingVertical="2dp"
        android:text="@string/common_got_it"
        android:textColor="@color/neutral_900"
        android:textSize="10.33sp"
        app:layout_goneMarginLeft="26.66dp"
        app:layout_constraintTop_toBottomOf="@id/tv_description"
        app:layout_constraintLeft_toRightOf="@id/tv_negative"
        app:layout_constraintRight_toRightOf="@id/view_background"
        tools:ignore="SmallSp" />

    <Space
        android:id="@+id/space_bottom"
        android:layout_width="0dp"
        android:layout_height="10.66dp"
        app:layout_constraintTop_toBottomOf="@id/tv_positive"
        app:layout_constraintBottom_toTopOf="@id/iv_bottom_arrow"
        app:layout_constraintLeft_toLeftOf="@id/view_background"
        app:layout_constraintRight_toRightOf="@id/view_background" />

</androidx.constraintlayout.widget.ConstraintLayout>
