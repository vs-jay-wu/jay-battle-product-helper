<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    tools:parentTag="android.widget.LinearLayout">

    <ImageView
        android:id="@+id/iv_mqces_illustration"
        android:layout_width="@dimen/quiz_mvb_qc_state_illustration_size"
        android:layout_height="@dimen/quiz_mvb_qc_state_illustration_size"
        android:layout_gravity="center_horizontal"
        android:contentDescription="@null"
        android:src="@drawable/img_mvb_qc_empty" />

    <TextView
        android:id="@+id/tv_mqces_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/mvb_spacing_300"
        android:fontFamily="sans-serif"
        android:includeFontPadding="false"
        android:text="@string/mvb_qc_empty_state_title"
        android:textColor="@color/neutral_900"
        android:textSize="@dimen/quiz_mvb_text_xl"
        android:textStyle="bold" />

    <TextView
        android:id="@+id/tv_mqces_message"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="center_horizontal"
        android:layout_marginTop="@dimen/mvb_spacing_150"
        android:fontFamily="sans-serif"
        android:includeFontPadding="false"
        android:text="@string/mvb_qc_empty_state_message"
        android:textColor="@color/neutral_900"
        android:textSize="@dimen/quiz_mvb_text_lg" />
</merge>
